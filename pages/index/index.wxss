/* 纪念日小卡片 */
.anniversary-card {
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
  padding: 30rpx 34rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 32rpx;
  background: linear-gradient(135deg, #fff3ec, #ffe1d4);
  box-shadow:
    0 14rpx 34rpx rgba(216, 83, 58, 0.12),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  transition: transform 0.22s ease;
}
.anniversary-card:active {
  transform: translateY(2rpx);
}
.anniversary-glow {
  position: absolute;
  right: -40rpx;
  top: -50rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: radial-gradient(
    circle,
    rgba(255, 173, 142, 0.55),
    rgba(255, 173, 142, 0)
  );
}
.anniversary-copy {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
}
.anniversary-title {
  color: #b46a52;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}
.anniversary-count {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  margin-top: 6rpx;
  color: #e95c47;
  transform-origin: center;
  transform-style: preserve-3d;
}
.anniversary-count.is-flipping.flip-frame-0 .anniversary-days {
  animation: anniversary-page-flip 0.18s ease-in-out;
}
.anniversary-count.is-flipping.flip-frame-1 .anniversary-days {
  animation: anniversary-page-flip-alt 0.18s ease-in-out;
}
.anniversary-prefix,
.anniversary-suffix {
  font-size: 26rpx;
  font-weight: 700;
}
.anniversary-days {
  display: inline-block;
  font-size: 64rpx;
  font-weight: 800;
  letter-spacing: -1rpx;
  line-height: 1;
  transform-origin: center;
}
.anniversary-since {
  margin-top: 8rpx;
  color: #b79086;
  font-size: 19rpx;
}
.anniversary-heart {
  position: relative;
  z-index: 1;
  color: #ef654d;
  font-size: 64rpx;
  opacity: 0.85;
}

@keyframes anniversary-page-flip {
  0% {
    opacity: 0.58;
    transform: perspective(460rpx) rotateX(72deg) translateY(-8rpx);
  }
  52% {
    opacity: 1;
    transform: perspective(460rpx) rotateX(-12deg) translateY(2rpx);
  }
  100% {
    opacity: 1;
    transform: perspective(460rpx) rotateX(0deg) translateY(0);
  }
}
@keyframes anniversary-page-flip-alt {
  0% {
    opacity: 0.58;
    transform: perspective(460rpx) rotateX(72deg) translateY(-8rpx);
  }
  52% {
    opacity: 1;
    transform: perspective(460rpx) rotateX(-12deg) translateY(2rpx);
  }
  100% {
    opacity: 1;
    transform: perspective(460rpx) rotateX(0deg) translateY(0);
  }
}
.anniversary-empty {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
}
.anniversary-empty-text {
  color: #c2705a;
  font-size: 24rpx;
  font-weight: 700;
}
.anniversary-empty-arrow {
  color: #e4674f;
  font-size: 34rpx;
  font-weight: 700;
}

