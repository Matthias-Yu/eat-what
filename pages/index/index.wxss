}
.setting-value {
  margin-right: 7rpx;
  color: #78a18a;
  font-size: 17rpx;
}
.setting-arrow {
  color: #c0b2ac;
  font-size: 32rpx;
}
.version {
  margin-top: 31rpx;
  color: #c1b1aa;
  font-size: 18rpx;
