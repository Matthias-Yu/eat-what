  font-size: 19rpx;
  line-height: 51rpx;
  font-weight: 600;
}
.filter-tabs text.is-active {
  background: #fff;
  color: #e8664d;
  box-shadow: 0 4rpx 13rpx rgba(80, 46, 32, 0.08);
}
.toolbar-hint {
  color: #806f67;
  font-size: 18rpx;
  font-weight: 600;
}
.todo-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.todo-item {
  min-height: 142rpx;
  display: flex;
  align-items: flex-start;
  padding: 24rpx 20rpx;
  border: 1rpx solid #f0e5de;
  border-radius: 27rpx;
  box-sizing: border-box;
  background: #fff;
  box-shadow: 0 7rpx 22rpx rgba(75, 45, 34, 0.045);
  transition: transform 0.15s ease;
}
.todo-item--pressed {
  transform: scale(0.985);
}
.todo-checkbox {
  width: 42rpx;
  height: 42rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 2rpx;
  border: 3rpx solid #e9a08c;
  border-radius: 50%;
  box-sizing: border-box;
  color: #fff;
  font-size: 24rpx;
}
.todo-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  margin: 0 17rpx;
}
.todo-title {
  font-size: 25rpx;
  font-weight: 700;
}
.todo-note {
  margin-top: 6rpx;
  color: #74635b;
  font-size: 19rpx;
  font-weight: 600;
}
.todo-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 13rpx;
}
.todo-category {
  padding: 4rpx 11rpx;
  border-radius: 11rpx;
  background: #f2edfb;
  color: #836bb7;
  font-size: 17rpx;
}
.category-housework {
  background: #e9f5ef;
  color: #578e75;
}
.category-shopping {
  background: #fff1e3;
  color: #d9834f;
}
.category-work {
  background: #e9f0fa;
  color: #6681a5;
}
.todo-due {
  color: #7d6a62;
  font-size: 17rpx;
  font-weight: 600;
}
.todo-more {
  color: #8d7a72;
  font-size: 27rpx;
  letter-spacing: 2rpx;
}
.todo-item.is-completed {
  background: rgba(255, 255, 255, 0.58);
  box-shadow: none;
}
.todo-item.is-completed .todo-checkbox {
  border-color: #7fb299;
  background: #7fb299;
}
.todo-item.is-completed .todo-title {
  color: #81736c;
  text-decoration: line-through;
}
.todo-item.is-completed .todo-note {
  color: #8a7d76;
}
.todo-empty {
  min-height: 450rpx;
}
.new-todo-button {
  height: 82rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 28rpx 0 0;
  padding: 0;
  border-radius: 27rpx;
  background: linear-gradient(135deg, #f17a5d, #e95e48);
  color: #fff;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 700;
  box-shadow: 0 13rpx 28rpx rgba(218, 87, 62, 0.2);
}
.new-todo-button text {
  margin-right: 8rpx;
  font-size: 31rpx;
  line-height: 1;
}

/* Wishlist */
.wishlist-page {
  background: linear-gradient(
    180deg,
    rgba(255, 251, 244, 0.08),
    rgba(255, 247, 241, 0.04) 520rpx,
    transparent 760rpx
  );
}
.wishlist-hero-card {
  position: relative;
  min-height: 300rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 32rpx;
  border: 2rpx solid rgba(199, 147, 117, 0.28);
  border-radius: 36rpx;
  box-sizing: border-box;
  background: linear-gradient(135deg, #fff7ed, #f6ded0);
  color: #5d4940;
  box-shadow: 0 22rpx 52rpx rgba(164, 112, 84, 0.12);
}
.wishlist-hero-image {
  position: absolute;
  z-index: 0;
  inset: 0;
  width: 100%;
  height: 100%;
  opacity: 0.66;
}
.wishlist-hero-shade {
  position: absolute;
  z-index: 1;
  inset: 0;
  background:
    radial-gradient(circle at 18% 18%, rgba(255, 251, 241, 0.86), rgba(255, 251, 241, 0) 44%),
    linear-gradient(90deg, rgba(255, 247, 234, 0.88), rgba(255, 232, 217, 0.58) 50%, rgba(255, 238, 225, 0.14) 78%);
  pointer-events: none;
}
.wishlist-hero-copy {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  width: 58%;
}
.wishlist-hero-copy .page-kicker {
  color: #b9785e;
}
.wishlist-title {
  margin-top: 7rpx;
  color: #5d4940;
  font-size: 45rpx;
  line-height: 1.18;
  font-weight: 800;
}
.wishlist-subtitle {
  margin-top: 11rpx;
  color: #8d7163;
  font-size: 21rpx;
}
.wishlist-progress {
  width: 100%;
  margin-top: 26rpx;
}
.wishlist-progress-copy {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #7d6255;
  font-size: 17rpx;
  font-weight: 600;
}
.wishlist-progress-track {
  height: 9rpx;
  overflow: hidden;
  margin-top: 9rpx;
  border-radius: 9rpx;
  background: rgba(206, 169, 146, 0.26);
}
.wishlist-progress-track view {
  height: 100%;
  min-width: 0;
  border-radius: 9rpx;
  background: linear-gradient(90deg, #e99b70, #f2c77f);
  transition: width 0.35s ease;
}
.wishlist-stats {
  display: flex;
  overflow: hidden;
  margin-top: 22rpx;
  border: 2rpx solid rgba(161, 122, 101, 0.28);
  border-radius: 28rpx;
  background: rgba(255, 249, 237, 0.88);
}
.wishlist-stats > view {
  min-width: 0;
  min-height: 106rpx;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 0 12rpx;
  border-right: 1rpx solid #eadfd2;
  box-sizing: border-box;
}
.wishlist-stats > view:last-child { border-right: 0; }
.wishlist-stats > view > text {
  width: 40rpx;
  height: 40rpx;
  border-radius: 14rpx;
  background: #f8ead8;
  color: #b17a50;
  font-size: 22rpx;
  line-height: 40rpx;
  text-align: center;
  font-weight: 800;
}
.wishlist-stats > view.is-completed > text { background: #e8efe3; color: #6e8768; }
.wishlist-stats > view.is-total > text { background: #eee7f2; color: #837092; }
.wishlist-stats > view > view {
  display: flex;
  flex-direction: column;
}
.wishlist-stats > view > view text:first-child {
  color: #5b493f;
  font-size: 31rpx;
  line-height: 1;
  font-weight: 800;
}
.wishlist-stats > view > view text:last-child {
  margin-top: 6rpx;
  color: #75655d;
  font-size: 16rpx;
  font-weight: 600;
}
.wishlist-action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin: 34rpx 0 18rpx;
}
.wishlist-action-row > view:first-child {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
}
.wishlist-action-row .section-title { color: #5d4940; }
.wishlist-action-row .section-subtitle { color: #715f56; }
.new-wish-button {
  width: 142rpx;
  height: 52rpx;
  flex: 0 0 142rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 7rpx;
  border-radius: 26rpx;
  border: 2rpx solid rgba(143, 83, 74, 0.28);
  background: #ad7069;
  color: #fff;
  font-size: 21rpx;
  line-height: 52rpx;
  font-weight: 700;
  box-shadow: none;
}
.new-wish-button text:first-child { font-size: 28rpx; font-weight: 500; }
.new-wish-button--pressed {
  transform: scale(0.96);
  opacity: 0.9;
}
.wish-card-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.wish-card {
  position: relative;
  overflow: hidden;
  min-height: 224rpx;
  padding: 25rpx 26rpx 24rpx 30rpx;
  border: 2rpx solid rgba(126, 145, 108, 0.34);
  border-radius: 32rpx;
  box-sizing: border-box;
  background: linear-gradient(155deg, rgba(255, 252, 242, 0.96), rgba(235, 241, 224, 0.94));
  box-shadow: none;
  transition: transform 0.18s ease, border-color 0.18s ease;
}
.wish-card::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  width: 8rpx;
  height: 100%;
  background: #84966e;
}
.wish-card.wish-tone-peach {
  border-color: rgba(190, 127, 109, 0.36);
  background: linear-gradient(155deg, rgba(255, 251, 242, 0.96), rgba(247, 224, 214, 0.94));
}
.wish-card.wish-tone-peach::before { background: #c98575; }
.wish-card.wish-tone-lavender {
  border-color: rgba(145, 123, 160, 0.34);
  background: linear-gradient(155deg, rgba(255, 251, 243, 0.96), rgba(238, 230, 242, 0.94));
}
.wish-card.wish-tone-lavender::before { background: #9b83a8; }
.wish-card--pressed {
  transform: scale(0.985);
}
.wish-card-top,
.wish-card-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.wish-card-stamp {
  width: 54rpx;
  height: 54rpx;
  border-radius: 19rpx;
  background: #e7eddf;
  color: #718466;
  font-size: 31rpx;
  line-height: 54rpx;
  text-align: center;
  font-weight: 800;
}
.wish-card-label {
  display: flex;
  align-items: center;
  gap: 11rpx;
}
.wish-card-label > text {
  color: #68765e;
  font-size: 15rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}
.wish-tone-peach .wish-card-stamp { background: #f5dfd6; color: #ad6e60; }
.wish-tone-peach .wish-card-label > text { color: #ad8174; }
.wish-tone-lavender .wish-card-stamp { background: #eae2ef; color: #7e698d; }
.wish-tone-lavender .wish-card-label > text { color: #8f7b98; }
