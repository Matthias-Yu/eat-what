.flying-dish-card {
  position: fixed;
  z-index: 90;
  display: flex;
  align-items: center;
  padding: 9rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.95);
  border-radius: 26rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.97);
  box-shadow: 0 9rpx 22rpx rgba(115, 61, 42, 0.2);
  transform: translate3d(0, 0, 0);
  transform-origin: 50% 50%;
  backface-visibility: hidden;
  will-change: transform, opacity;
  animation: card-fly 1.7s cubic-bezier(0.2, 0.72, 0.24, 1) forwards;
  pointer-events: none;
}
.flying-card-art {
  width: 86rpx;
