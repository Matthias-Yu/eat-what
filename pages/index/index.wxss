  border-radius: 21rpx;
  background: #fff0e5;
  font-size: 39rpx;
  line-height: 70rpx;
  text-align: center;
}
.order-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  margin: 0 14rpx;
}
.order-title {
  overflow: hidden;
  font-size: 21rpx;
  font-weight: 650;
  white-space: nowrap;
  text-overflow: ellipsis;
}
.order-time {
  margin-top: 7rpx;
  color: #ad9e97;
  font-size: 16rpx;
}
.order-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}
.order-status {
  color: #70a187;
  font-size: 16rpx;
}
.order-arrow {
  margin-top: 4rpx;
  color: #c3b5ae;
  font-size: 27rpx;
}
.empty-order {
  min-height: 108rpx;
