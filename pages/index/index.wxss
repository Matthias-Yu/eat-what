  height: 100%;
  margin: 0;
  padding: 0;
  border-radius: 0;
  background: transparent;
  opacity: 0;
}
.share-hit-area::after {
  border: 0;
}
.setting-icon {
  width: 49rpx;
  height: 49rpx;
  margin-right: 16rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  line-height: 49rpx;
  text-align: center;
  font-weight: 700;
}
.setting-orange {
  background: #fff0e7;
  color: #e56a4f;
}
.setting-menu {
  background: #eef7f0;
  color: #5d9b7a;
}
.setting-cloud {
  background: #eaf4fb;
  color: #5f94b7;
}
.setting-pink {
  background: #fff0f1;
  color: #dc7381;
}
.setting-gray {
  background: #f2efed;
  color: #887a73;
}
.setting-row > text:nth-child(2) {
