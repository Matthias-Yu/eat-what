}
.farm-mood-strip > view {
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border-radius: 18rpx;
  background: rgba(255, 248, 236, 0.72);
  color: #6b7b4b;
  font-size: 20rpx;
  font-weight: 800;
}
.farm-mood-strip text:first-child {
  color: #d98d3a;
  font-size: 22rpx;
}
.farm-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}
.farm-stats-shell {
  margin: 0 0 34rpx;
  padding: 16rpx;
}
.farm-stats > view {
  height: 112rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(232, 221, 201, 0.58);
  border-radius: 22rpx;
  background: rgba(255, 253, 248, 0.88);
  box-shadow:
    0 8rpx 18rpx rgba(91, 79, 62, 0.05),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}
.farm-stats text:first-child {
  color: #3f754c;
  font-size: 38rpx;
  font-weight: 850;
}
.farm-stats text:last-child {
  margin-top: 4rpx;
  color: #a18f86;
  font-size: 20rpx;
}
.farm-section-heading {
  margin-top: 34rpx;
  margin-bottom: 16rpx;
}
.farm-section-heading .section-title::before {
  background: linear-gradient(180deg, #7bb96f, #f0b25a);
}
.farm-seed-tray {
  padding: 16rpx;
}
.farm-crop-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}
.farm-crop-chip {
  position: relative;
  min-width: 0;
  height: 134rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  overflow: hidden;
  padding: 10rpx 12rpx 10rpx 10rpx;
  border: 1rpx solid rgba(232, 221, 201, 0.58);
  border-radius: 22rpx;
  box-sizing: border-box;
  background: rgba(255, 253, 248, 0.88);
  box-shadow:
    0 8rpx 16rpx rgba(91, 79, 62, 0.04),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.74);
}
.farm-crop-chip.is-active {
  border-color: rgba(91, 151, 83, 0.92);
  background: rgba(246, 255, 235, 0.96);
  transform: translateY(-2rpx);
  box-shadow:
    0 12rpx 22rpx rgba(78, 130, 78, 0.14),
    inset 0 0 0 3rpx rgba(255, 255, 255, 0.6);
}
.farm-crop-check {
  position: absolute;
  z-index: 3;
  top: 9rpx;
  right: 9rpx;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #75b56d;
  color: #fff;
  font-size: 17rpx;
  font-weight: 900;
  line-height: 28rpx;
  text-align: center;
  opacity: 0;
  transform: scale(0.72);
  transition: opacity 0.18s ease, transform 0.18s ease;
}
.farm-crop-chip.is-active .farm-crop-check {
  opacity: 1;
  transform: scale(1);
}
.farm-crop-image {
  position: relative;
  z-index: 1;
  width: 92rpx;
  height: 92rpx;
  flex-shrink: 0;
  border: 1rpx solid rgba(255, 255, 255, 0.78);
  border-radius: 18rpx;
  box-sizing: border-box;
  background: #fff7e7;
  box-shadow:
    0 6rpx 12rpx rgba(82, 65, 43, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
}
.farm-crop-info {
  position: relative;
  z-index: 1;
  min-width: 0;
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
}
.farm-crop-name {
  position: relative;
  z-index: 1;
  color: #3d302a;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.2;
}
.farm-crop-meta {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 5rpx;
  margin-top: 10rpx;
}
.farm-crop-meta text {
  height: 30rpx;
  padding: 0 9rpx;
  border-radius: 999rpx;
  background: rgba(255, 247, 222, 0.86);
  color: #8d745d;
  font-size: 17rpx;
  font-weight: 750;
  line-height: 30rpx;
}
.farm-field-shell {
  position: relative;
  overflow: hidden;
  margin-top: 24rpx;
  height: 1040rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.84);
  border-radius: 36rpx;
  box-sizing: border-box;
  background: #e9d39f;
  box-shadow:
    0 22rpx 46rpx rgba(76, 116, 63, 0.18),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
}
.farm-field-shell::before {
  content: "";
  position: absolute;
  inset: 10rpx;
  z-index: 1;
  border: 1rpx solid rgba(255, 255, 255, 0.42);
  border-radius: 28rpx;
  pointer-events: none;
}
.farm-field-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}
.farm-field {
  position: absolute;
  inset: 0;
  z-index: 2;
}
.farm-plot {
  position: absolute;
  width: 270rpx;
  height: 286rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  transform: translate(-50%, -50%);
  transition: transform 0.18s ease;
}
.farm-plot-1 {
  left: 31%;
  top: 26%;
}
.farm-plot-2 {
  left: 69%;
  top: 26%;
}
.farm-plot-3 {
  left: 31%;
  top: 45%;
}
.farm-plot-4 {
  left: 69%;
  top: 45%;
}
.farm-plot-5 {
  left: 31%;
  top: 65%;
}
.farm-plot-6 {
  left: 69%;
  top: 65%;
}
.farm-plot--pressed {
  transform: translate(-50%, -48%) scale(0.96);
}
.farm-crop-pin {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}
.farm-growth-wrap {
  position: relative;
  z-index: 1;
  width: 216rpx;
  height: 216rpx;
  transform-origin: 50% 92%;
  animation: farm-grow-in 0.48s ease both;
}
.farm-growth-wrap--sprout {
  width: 164rpx;
  height: 164rpx;
}
.farm-growth-wrap--seedling {
  width: 190rpx;
  height: 190rpx;
}
.farm-growth-wrap--growing {
  width: 226rpx;
  height: 226rpx;
}
.farm-growth-wrap--ready {
  width: 254rpx;
  height: 254rpx;
}
.farm-growth-image {
  position: absolute;
  left: 50%;
  bottom: 0;
  z-index: 1;
  display: block;
  width: 216rpx;
  height: 216rpx;
  transform: translateX(-50%);
  transform-origin: 50% 92%;
  filter: drop-shadow(0 12rpx 10rpx rgba(48, 34, 22, 0.18));
  animation: none;
}
.farm-growth-image--soil {
  z-index: 1;
  clip-path: inset(66% 0 0 0);
}
.farm-growth-image--leaf {
  z-index: 2;
  clip-path: inset(0 0 26% 0);
  animation: farm-leaf-sway 3.6s ease-in-out 0.5s infinite;
}
.farm-growth-image--sprout {
  width: 164rpx;
  height: 164rpx;
}
.farm-growth-image--seedling {
  width: 190rpx;
  height: 190rpx;
}
.farm-growth-image--growing {
  width: 226rpx;
  height: 226rpx;
}
.farm-growth-image--ready {
  width: 254rpx;
  height: 254rpx;
  filter:
    drop-shadow(0 12rpx 10rpx rgba(48, 34, 22, 0.18))
    drop-shadow(0 0 12rpx rgba(255, 215, 98, 0.38));
}
.farm-growth-image--ready.farm-growth-image--leaf {
  animation: farm-leaf-ready-breathe 2.6s ease-in-out 0.5s infinite;
}
@keyframes farm-grow-in {
  0% {
    opacity: 0;
    transform: translateY(16rpx) scale(0.72);
  }
  72% {
    opacity: 1;
    transform: translateY(-3rpx) scale(1.04);
  }
  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}
@keyframes farm-leaf-sway {
  0%,
  100% {
    transform: translateX(-50%) rotate(-1.2deg) scale(1);
  }
  50% {
    transform: translateX(-50%) rotate(1.4deg) scale(1.02);
  }
}
@keyframes farm-leaf-ready-breathe {
  0%,
  100% {
    transform: translateX(-50%) translateY(0) scale(1);
  }
  50% {
    transform: translateX(-50%) translateY(-3rpx) scale(1.04);
  }
}
.farm-crop-tag {
  position: absolute;
  z-index: 2;
  right: 38rpx;
  top: 24rpx;
  min-width: 64rpx;
  height: 48rpx;
  padding: 0 14rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 999rpx 999rpx 999rpx 14rpx;
  box-sizing: border-box;
  background: rgba(255, 252, 232, 0.86);
  box-shadow:
    0 8rpx 16rpx rgba(72, 83, 44, 0.1),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
  color: #6c7d4c;
  font-size: 18rpx;
  font-weight: 800;
  line-height: 44rpx;
  text-align: center;
  backdrop-filter: blur(1px);
  -webkit-backdrop-filter: blur(1px);
}
.farm-plot.is-ready .farm-crop-tag {
  background: rgba(255, 238, 172, 0.9);
  color: #9c5b1f;
}
.farm-inventory {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}
.farm-inventory-item {
  min-height: 106rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 18rpx;
  border: 1rpx solid rgba(232, 221, 201, 0.62);
  border-radius: 24rpx;
  box-sizing: border-box;
  background: rgba(255, 253, 248, 0.9);
  box-shadow:
    0 10rpx 24rpx rgba(91, 79, 62, 0.05),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}
.farm-inventory-item > text {
  width: 62rpx;
  height: 62rpx;
  flex-shrink: 0;
  border-radius: 22rpx;
  background: linear-gradient(145deg, #edf8db, #d4efbd);
  font-size: 35rpx;
  line-height: 62rpx;
  text-align: center;
  box-shadow: inset 0 -4rpx 8rpx rgba(68, 113, 65, 0.08);
}
.farm-inventory-item view {
  display: flex;
  flex-direction: column;
}
.farm-inventory-item view text:first-child {
  color: #40322d;
  font-size: 23rpx;
  font-weight: 800;
}
.farm-inventory-item view text:last-child {
  margin-top: 4rpx;
  color: #9b8b82;
  font-size: 20rpx;
}
.farm-empty-store {
  position: relative;
  min-height: 238rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  overflow: hidden;
  padding: 26rpx 28rpx;
}
.farm-empty-visual {
  position: relative;
  z-index: 1;
  width: 174rpx;
  height: 174rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(232, 221, 201, 0.62);
  border-radius: 30rpx;
  background: rgba(255, 248, 236, 0.76);
  box-shadow:
    0 10rpx 18rpx rgba(91, 79, 62, 0.05),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
}
.farm-empty-image {
  width: 150rpx;
  height: 150rpx;
}
.farm-empty-copy {
  position: relative;
  z-index: 1;
  min-width: 0;
  display: flex;
  flex: 1;
  flex-direction: column;
}
.farm-empty-title {
  color: #40322d;
  font-size: 29rpx;
  font-weight: 850;
  line-height: 1.2;
}
.farm-empty-subtitle {
  margin-top: 10rpx;
  color: #9a8b82;
  font-size: 21rpx;
  line-height: 1.35;
}
.farm-empty-slots {
  display: flex;
  gap: 10rpx;
  margin-top: 22rpx;
}
.farm-empty-slots text {
  width: 54rpx;
  height: 54rpx;
  border: 2rpx dashed rgba(127, 177, 111, 0.44);
  border-radius: 18rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.48);
  color: rgba(91, 145, 88, 0.62);
  font-size: 28rpx;
  font-weight: 800;
  line-height: 50rpx;
  text-align: center;
}

@media (max-width: 340px) {
  .hero-card {
    height: 330rpx;
  }
  .hero-art {
    right: -30rpx;
    transform: scale(0.86);
  }
  .hero-title {
    font-size: 43rpx;
  }
  .food-art {
    height: 184rpx;
  }
}
