/* 随机选菜弹层 */
.random-overlay {
  z-index: 120;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}
.random-card {
  position: relative;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
