.stats-card > view:not(.stats-divider) {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.stats-number {
  color: #493832;
  font-size: 35rpx;
  font-weight: 800;
}
.stats-number text {
  font-size: 19rpx;
}
.stats-label {
  margin-top: 4rpx;
  color: #a89891;
  font-size: 18rpx;
}
.stats-divider {
  width: 1rpx;
  height: 46rpx;
  background: #eee2dc;
}
.profile-section-title {
  margin: 34rpx 3rpx 17rpx;
  font-size: 26rpx;
  font-weight: 750;
}
.order-section-title {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}
.order-section-title .section-more {
