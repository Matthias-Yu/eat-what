/* 纪念日小卡片 */
.anniversary-card {
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
  padding: 30rpx 34rpx;
  border: 2rpx solid rgba(202, 105, 76, 0.3);
  border-radius: 32rpx;
  background: linear-gradient(135deg, #fff3ec, #ffe1d4);
  box-shadow:
    0 16rpx 36rpx rgba(180, 76, 52, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  transition: transform 0.22s ease;
}
.anniversary-card:active {
  transform: translateY(2rpx);
}
.anniversary-glow {
  position: absolute;
  right: -40rpx;
  top: -50rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: radial-gradient(
    circle,
    rgba(255, 173, 142, 0.55),
    rgba(255, 173, 142, 0)
  );
}
.anniversary-copy {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
}
.anniversary-title {
  color: #b46a52;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}
.anniversary-count {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  margin-top: 6rpx;
  color: #e95c47;
  transform-origin: center;
  transform-style: preserve-3d;
}
.anniversary-count.is-flipping.flip-frame-0 .anniversary-days {
  animation: anniversary-page-flip 0.18s ease-in-out;
}
.anniversary-count.is-flipping.flip-frame-1 .anniversary-days {
  animation: anniversary-page-flip-alt 0.18s ease-in-out;
}
.anniversary-prefix,
.anniversary-suffix {
  font-size: 26rpx;
  font-weight: 700;
}
.anniversary-days {
  display: inline-block;
  font-size: 64rpx;
  font-weight: 800;
