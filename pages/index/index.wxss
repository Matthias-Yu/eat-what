  font-size: 38rpx;
  line-height: 76rpx;
  text-align: center;
  box-shadow: 0 8rpx 22rpx rgba(75, 42, 30, 0.07);
}
.header-cart-badge {
  position: absolute;
  top: -7rpx;
  right: -6rpx;
  min-width: 30rpx;
  height: 30rpx;
  padding: 0 5rpx;
  box-sizing: border-box;
  border: 3rpx solid #fff;
  border-radius: 16rpx;
  background: #ed604a;
  color: #fff;
  font-size: 17rpx;
