.flower-mood-strip text:first-child {
  color: #d47aa0;
}
.flower-stats-shell {
  margin: 0 0 34rpx;
  padding: 16rpx;
}
.flower-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}
.flower-stats > view {
  height: 112rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(238, 213, 224, 0.58);
  border-radius: 22rpx;
  background: rgba(255, 253, 251, 0.9);
}
.flower-stats text:first-child {
  color: #b25f88;
  font-size: 38rpx;
  font-weight: 850;
}
.flower-stats text:last-child {
  margin-top: 4rpx;
  color: #765f6c;
  font-size: 20rpx;
  font-weight: 600;
}
.flower-section-heading {
  margin-top: 34rpx;
  margin-bottom: 16rpx;
}
.flower-section-heading .section-title::before {
  background: linear-gradient(180deg, #e983ab, #b9a8ff);
}
.flower-seed-tray {
  padding: 16rpx;
}
.flower-type-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}
.flower-type-chip {
  position: relative;
  min-width: 0;
  min-height: 154rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  overflow: hidden;
  padding: 10rpx 12rpx 10rpx 10rpx;
  border: 1rpx solid rgba(238, 213, 224, 0.64);
  border-radius: 22rpx;
  box-sizing: border-box;
  background: rgba(255, 253, 251, 0.9);
  box-shadow: 0 8rpx 16rpx rgba(124, 82, 103, 0.04);
}
.flower-type-chip.is-active {
  border-color: rgba(210, 112, 153, 0.9);
  background: rgba(255, 245, 250, 0.98);
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 22rpx rgba(192, 104, 148, 0.12);
}
.flower-type-check {
  position: absolute;
  z-index: 3;
  top: 9rpx;
  right: 9rpx;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #d7779d;
  color: #fff;
  font-size: 17rpx;
  font-weight: 900;
  line-height: 28rpx;
  text-align: center;
  opacity: 0;
  transform: scale(0.72);
}
.flower-type-chip.is-active .flower-type-check {
  opacity: 1;
  transform: scale(1);
}
.flower-type-image {
  width: 94rpx;
  height: 94rpx;
  flex-shrink: 0;
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  border-radius: 18rpx;
  box-sizing: border-box;
  background: #fff7fb;
}
.flower-type-info {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.flower-type-name {
  color: #40313a;
  font-size: 23rpx;
  font-weight: 850;
  line-height: 1.2;
}
.flower-type-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 5rpx;
  margin-top: 8rpx;
}
.flower-type-meta text {
  height: 28rpx;
  padding: 0 9rpx;
  border-radius: 999rpx;
  background: rgba(255, 241, 248, 0.9);
  color: #9b6c80;
  font-size: 16rpx;
  font-weight: 750;
  line-height: 28rpx;
}
.flower-type-meaning {
  margin-top: 7rpx;
  color: #7d6572;
  font-size: 17rpx;
  line-height: 1.2;
  font-weight: 600;
}
.flower-garden-shell {
  position: relative;
  overflow: hidden;
  margin-top: 24rpx;
  height: 1040rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.84);
  border-radius: 36rpx;
  box-sizing: border-box;
  background: #f2d9e3;
  box-shadow: 0 22rpx 46rpx rgba(158, 99, 128, 0.16);
}
.flower-garden-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}
.flower-garden {
  position: absolute;
  inset: 0;
  z-index: 2;
}
.flower-plot {
  position: absolute;
  width: 260rpx;
  height: 250rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transform: translate(-50%, -50%);
  transition: transform 0.18s ease;
}
.flower-plot-1 { left: 31%; top: 25%; }
.flower-plot-2 { left: 69%; top: 25%; }
.flower-plot-3 { left: 31%; top: 47%; }
.flower-plot-4 { left: 69%; top: 47%; }
.flower-plot-5 { left: 31%; top: 69%; }
.flower-plot-6 { left: 69%; top: 69%; }
.flower-plot--pressed {
  transform: translate(-50%, -48%) scale(0.96);
}
.flower-plant-pin {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.flower-plant-image {
  width: 178rpx;
  height: 178rpx;
  display: block;
  border-radius: 50%;
  filter: drop-shadow(0 12rpx 10rpx rgba(82, 50, 64, 0.14));
  transform-origin: 50% 92%;
  animation: flower-sway 3.8s ease-in-out infinite;
}
.flower-plant-image--sprout {
  width: 122rpx;
  height: 122rpx;
  opacity: 0.72;
}
.flower-plant-image--bud {
  width: 152rpx;
  height: 152rpx;
  opacity: 0.86;
}
.flower-plant-image--blooming {
  width: 190rpx;
  height: 190rpx;
}
.flower-plant-image--ready {
  width: 218rpx;
  height: 218rpx;
  filter:
    drop-shadow(0 12rpx 10rpx rgba(82, 50, 64, 0.14))
    drop-shadow(0 0 14rpx rgba(255, 210, 230, 0.48));
}
@keyframes flower-sway {
  0%,
  100% { transform: rotate(-1deg) scale(1); }
  50% { transform: rotate(1.2deg) scale(1.025); }
}
.flower-crop-tag {
  position: absolute;
  z-index: 2;
  right: 36rpx;
  top: 20rpx;
  min-width: 64rpx;
  height: 46rpx;
  padding: 0 14rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.84);
  border-radius: 999rpx 999rpx 999rpx 14rpx;
  box-sizing: border-box;
  background: rgba(255, 250, 253, 0.9);
  color: #8e6780;
  font-size: 18rpx;
  font-weight: 800;
  line-height: 42rpx;
  text-align: center;
}
.flower-plot.is-ready .flower-crop-tag {
  background: rgba(255, 229, 240, 0.94);
  color: #b4547f;
}
.flower-inventory {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}
.flower-inventory-item {
  min-height: 106rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 18rpx;
  border: 1rpx solid rgba(238, 213, 224, 0.62);
  border-radius: 24rpx;
  box-sizing: border-box;
  background: rgba(255, 253, 251, 0.92);
}
.flower-inventory-item image {
  width: 64rpx;
  height: 64rpx;
  flex-shrink: 0;
  border-radius: 20rpx;
  background: #fff7fb;
}
.flower-inventory-item view {
  display: flex;
  flex-direction: column;
}
.flower-inventory-item view text:first-child {
  color: #40313a;
  font-size: 23rpx;
  font-weight: 800;
}
.flower-inventory-item view text:last-child {
  margin-top: 4rpx;
  color: #765f6c;
  font-size: 20rpx;
  font-weight: 600;
}
.flower-empty-store {
  min-height: 210rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 26rpx 28rpx;
}
.flower-empty-visual {
  width: 122rpx;
  height: 122rpx;
  flex-shrink: 0;
  border-radius: 34rpx;
  background: linear-gradient(145deg, #ffe2ee, #eee5ff);
  color: #d7779d;
  font-size: 58rpx;
  line-height: 122rpx;
  text-align: center;
}
.flower-empty-copy {
  display: flex;
  flex-direction: column;
}
.flower-empty-title {
  color: #40313a;
  font-size: 29rpx;
  font-weight: 850;
}
.flower-empty-subtitle {
  margin-top: 10rpx;
  color: #9f8d96;
  font-size: 21rpx;
  line-height: 1.35;
}

@media (max-width: 340px) {
  .hero-card {
    height: 330rpx;
  }
  .hero-art {
    right: -30rpx;
    transform: scale(0.86);
  }
  .hero-title {
    font-size: 43rpx;
  }
  .food-art {
    height: 184rpx;
  }
}

/* AI 家庭助手 */
.ai-fab {
  position: fixed;
  right: 28rpx;
  bottom: calc(160rpx + env(safe-area-inset-bottom));
  z-index: 90;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffb37a, #f17a5c);
  box-shadow: 0 14rpx 30rpx rgba(216, 83, 58, 0.32);
}
.ai-fab-icon {
  color: #fff;
  font-size: 34rpx;
  line-height: 1;
}
.ai-fab-text {
  margin-top: 4rpx;
  color: #fff;
  font-size: 18rpx;
  font-weight: 700;
}
.ai-sheet {
  display: flex;
  flex-direction: column;
  height: 76vh;
}
.ai-config-tip {
  margin-bottom: 16rpx;
  padding: 16rpx 24rpx;
  border-radius: 20rpx;
  background: #fff3ea;
  color: #d8623f;
  font-size: 23rpx;
  font-weight: 600;
}
.ai-list {
  flex: 1;
  min-height: 0;
  padding: 8rpx 4rpx;
}
.ai-bubble-row {
  display: flex;
  margin-bottom: 20rpx;
}
.ai-bubble-row.is-user {
  justify-content: flex-end;
}
.ai-bubble-row.is-ai {
  justify-content: flex-start;
}
.ai-bubble {
  max-width: 78%;
  padding: 18rpx 24rpx;
  border-radius: 26rpx;
  font-size: 26rpx;
  line-height: 1.6;
  word-break: break-word;
}
.ai-bubble-row.is-ai .ai-bubble {
  background: #fff;
  color: #3c2f2b;
  border: 1rpx solid #f0e4dc;
  border-top-left-radius: 8rpx;
}
.ai-bubble-row.is-user .ai-bubble {
  background: linear-gradient(135deg, #f17a5c, #e95c47);
  color: #fff;
  border-top-right-radius: 8rpx;
}
.ai-bubble--typing {
  color: #b09f97;
}
.ai-compose {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 18rpx;
}
.ai-input {
  flex: 1;
  height: 80rpx;
  padding: 0 24rpx;
  border: 1rpx solid #ecdfd8;
  border-radius: 24rpx;
  box-sizing: border-box;
  background: #fff;
  font-size: 25rpx;
}
.ai-send {
  flex-shrink: 0;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 36rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #f17a5c, #e95c47);
  color: #fff;
  font-size: 25rpx;
  font-weight: 700;
  box-shadow: 0 11rpx 26rpx rgba(216, 83, 58, 0.18);
}
.ai-send.is-disabled {
  opacity: 0.5;
}

/* 卡片统一使用描边分层，不使用投影。 */
.hero-card,
.hero-card--new,
.quick-item,
.quick-item--pressed,
.mini-food-card,
.home-todo-card,
.food-card,
.progress-card,
.todo-item,
.wishlist-hero-card,
.wish-card,
.stats-card,
.order-card,
.settings-card,
.flying-dish-card,
.family-card,
.success-card,
.random-card,
.anniversary-card,
.messages-card,
.home-letter-arrival,
.letter-compose-card,
.letter-paper-card,
.farm-wallet,
.farm-hero,
.farm-panel,
.farm-mood-strip,
.farm-stats > view,
.farm-crop-chip,
.farm-field-shell,
.farm-inventory-item,
.farm-empty-visual,
.flower-wallet,
.flower-hero,
.flower-panel,
.flower-type-chip,
.flower-garden-shell {
  box-shadow: none;
}
