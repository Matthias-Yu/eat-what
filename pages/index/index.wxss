  color: #b97896;
  box-shadow: 0 10rpx 22rpx rgba(167, 99, 131, 0.13);
}
.header-cart {
  position: relative;
  width: 76rpx;
  height: 76rpx;
  border: 1rpx solid #f1e6df;
  border-radius: 25rpx;
  background: #fff;
  color: #d9674f;
  font-size: 38rpx;
  line-height: 76rpx;
  text-align: center;
  box-shadow: 0 8rpx 22rpx rgba(75, 42, 30, 0.07);
}
.header-cart-badge {
  position: absolute;
  top: -7rpx;
  right: -6rpx;
  min-width: 30rpx;
  height: 30rpx;
  padding: 0 5rpx;
  box-sizing: border-box;
  border: 3rpx solid #fff;
  border-radius: 16rpx;
  background: #ed604a;
  color: #fff;
  font-size: 17rpx;
  line-height: 27rpx;
}
.search-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 22rpx;
}
.search-box {
  flex: 1;
  height: 82rpx;
  display: flex;
  align-items: center;
  padding: 0 22rpx;
  border: 1rpx solid #f1e6df;
  border-radius: 25rpx;
  box-sizing: border-box;
  background: #fff;
  box-shadow: 0 7rpx 23rpx rgba(82, 50, 38, 0.045);
}
.dice-button {
  width: 82rpx;
  height: 82rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 25rpx;
  font-size: 40rpx;
  background: linear-gradient(150deg, #fff2e9, #ffd9c9);
  box-shadow:
    0 8rpx 20rpx rgba(225, 91, 67, 0.18),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
  transition: transform 0.24s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.search-icon {
  margin-right: 14rpx;
  color: #8e7c74;
  font-size: 39rpx;
  transform: rotate(-20deg);
}
.search-input {
  flex: 1;
  height: 100%;
  font-size: 24rpx;
}
.input-placeholder {
  color: #8f7c73;
}
.search-clear {
  width: 44rpx;
  color: #806e66;
  font-size: 38rpx;
  line-height: 44rpx;
  text-align: center;
}
.category-scroll {
  width: calc(100% + 30rpx);
  margin: 0 -30rpx 28rpx 0;
}
.category-row {
  display: flex;
  gap: 14rpx;
  padding-right: 30rpx;
}
.category-pill {
  flex: 0 0 auto;
  height: 66rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 0 22rpx;
  border: 1rpx solid #eee2db;
  border-radius: 33rpx;
  background: #fff;
  color: #8e7d75;
  font-size: 22rpx;
  font-weight: 600;
  box-sizing: border-box;
  transition:
    background-color 180ms ease,
    border-color 180ms ease,
    color 180ms ease,
    transform 180ms ease,
    box-shadow 180ms ease;
}
.category-pill.is-active {
  border-color: #ef684f;
  background: #ef684f;
  color: #fff;
  box-shadow: 0 8rpx 20rpx rgba(222, 92, 67, 0.2);
  transform: translateY(-1rpx);
}
.food-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}
.food-card {
  overflow: hidden;
  border: 2rpx solid rgba(151, 105, 72, 0.24);
  border-radius: 30rpx;
  box-sizing: border-box;
  background: linear-gradient(170deg, #ffffff, #fffaf6);
  box-shadow:
    0 12rpx 28rpx rgba(77, 46, 34, 0.06),
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.82);
  transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
}

.menu-page.stagger > .food-grid.food-grid--motion-a {
  opacity: 1;
  animation: food-grid-enter-a 280ms cubic-bezier(0.2, 0.82, 0.28, 1) both;
}

.menu-page.stagger > .food-grid.food-grid--motion-b {
  opacity: 1;
  animation: food-grid-enter-b 280ms cubic-bezier(0.2, 0.82, 0.28, 1) both;
}

@keyframes food-grid-enter-a {
  from { opacity: 0.72; transform: translateY(8rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes food-grid-enter-b {
  from { opacity: 0.72; transform: translateY(8rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.food-card:active {
  transform: translateY(2rpx);
  border-color: rgba(224, 112, 82, 0.42);
  box-shadow:
    0 8rpx 20rpx rgba(77, 46, 34, 0.08),
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.82);
}
.food-art {
  position: relative;
  height: 196rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.food-art-glow {
  position: absolute;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.38);
}
.food-image {
  position: relative;
  z-index: 1;
  width: 174rpx;
  height: 174rpx;
  filter: drop-shadow(0 14rpx 14rpx rgba(106, 64, 37, 0.14));
}
.food-emoji {
  position: relative;
  z-index: 1;
  font-size: 102rpx;
  filter: drop-shadow(0 10rpx 10rpx rgba(106, 64, 37, 0.12));
}
.recommend-mark {
  position: absolute;
  z-index: 2;
  top: 14rpx;
  left: 14rpx;
  padding: 7rpx 13rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.9);
  color: #e6654e;
  font-size: 17rpx;
  font-weight: 700;
}
.food-info {
  position: relative;
  min-height: 142rpx;
  padding: 16rpx 66rpx 17rpx 17rpx;
  box-sizing: border-box;
}
.food-name {
  display: block;
  overflow: hidden;
  font-size: 25rpx;
  font-weight: 750;
  white-space: nowrap;
  text-overflow: ellipsis;
}
.food-desc {
  display: block;
  overflow: hidden;
  margin-top: 7rpx;
  color: #76655d;
  font-size: 19rpx;
  font-weight: 600;
  white-space: nowrap;
  text-overflow: ellipsis;
}
.food-tags {
  display: flex;
  gap: 7rpx;
  margin-top: 10rpx;
}
.food-tags text {
  padding: 4rpx 9rpx;
  border-radius: 9rpx;
  background: #fff3ed;
  color: #da795e;
  font-size: 16rpx;
}
.add-button {
  width: 52rpx;
  height: 52rpx;
  font-size: 34rpx;
}
.food-info > .add-button {
  position: absolute;
  right: 15rpx;
  bottom: 16rpx;
}
.menu-empty,
.todo-empty {
  min-height: 560rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.empty-art {
  width: 150rpx;
  height: 150rpx;
  margin-bottom: 22rpx;
  border-radius: 50%;
  background: #fff0e7;
  font-size: 74rpx;
  line-height: 150rpx;
  text-align: center;
}
.empty-title {
  color: #4b3d37;
  font-size: 28rpx;
  font-weight: 750;
}
.empty-subtitle {
  margin-top: 10rpx;
  color: #77665e;
  font-size: 21rpx;
  font-weight: 600;
}
.menu-empty button {
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 25rpx;
  padding: 0 28rpx;
  border-radius: 34rpx;
  background: #ef684f;
  color: #fff;
  font-size: 21rpx;
  line-height: 1;
}

/* Todo */
.todo-date-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  border: 8rpx solid #f6c7b9;
  background: #fff;
  color: #e86149;
  font-size: 25rpx;
  line-height: 62rpx;
  text-align: center;
  font-weight: 800;
  box-sizing: border-box;
}
.todo-date-icon text {
  font-size: 14rpx;
}
.progress-card {
  padding: 28rpx;
  border-radius: 31rpx;
  background: linear-gradient(135deg, #fff0e6, #ffe4d7);
  box-shadow: 0 10rpx 30rpx rgba(184, 104, 72, 0.09);
}
.progress-title {
  display: block;
  color: #533b32;
  font-size: 27rpx;
  font-weight: 750;
}
.progress-copy {
  display: block;
  margin-top: 7rpx;
  color: #835447;
  font-size: 20rpx;
  font-weight: 600;
}
.progress-sun {
  width: 58rpx;
  height: 58rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.6);
  color: #e98158;
  font-size: 30rpx;
  line-height: 58rpx;
  text-align: center;
}
.progress-track {
  height: 12rpx;
  overflow: hidden;
  margin-top: 24rpx;
  border-radius: 6rpx;
  background: rgba(219, 142, 111, 0.2);
}
.progress-fill {
  height: 100%;
  min-width: 2%;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #f1845e, #eb5f49);
  transition: width 0.35s ease;
}
.todo-toolbar {
  margin: 33rpx 0 20rpx;
}
.filter-tabs {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx;
  border-radius: 24rpx;
  background: #f5ede7;
}
.filter-tabs text {
  height: 51rpx;
  padding: 0 17rpx;
  border-radius: 19rpx;
