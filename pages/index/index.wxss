  display: flex;
  flex-direction: column;
}
.empty-order view text:first-child {
  font-size: 21rpx;
  font-weight: 650;
}
.empty-order view text:last-child {
  margin-top: 5rpx;
  color: #aa9a93;
  font-size: 17rpx;
}
.empty-order > text:last-child {
  color: #e66b52;
  font-size: 19rpx;
}
.settings-card {
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 30rpx;
  background: linear-gradient(170deg, #ffffff, #fffaf6);
  box-shadow:
    0 12rpx 30rpx rgba(80, 50, 36, 0.05),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}
.setting-row {
  position: relative;
  height: 95rpx;
  display: flex;
  align-items: center;
  padding: 0 21rpx;
  border-bottom: 1rpx solid #f5ece7;
