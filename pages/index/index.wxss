  margin-bottom: 22rpx;
}
.search-box {
  flex: 1;
  height: 82rpx;
  display: flex;
  align-items: center;
  padding: 0 22rpx;
  border: 1rpx solid #f1e6df;
  border-radius: 25rpx;
  box-sizing: border-box;
  background: #fff;
  box-shadow: 0 7rpx 23rpx rgba(82, 50, 38, 0.045);
