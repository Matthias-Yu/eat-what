/* Floating cart */
.cart-float {
  position: fixed;
  z-index: 45;
  left: 42rpx;
  right: 42rpx;
  bottom: calc(142rpx + env(safe-area-inset-bottom));
  height: 92rpx;
  display: flex;
  align-items: center;
  padding: 0 13rpx;
  border-radius: 30rpx;
  background: #3e332f;
  color: #fff;
  box-shadow: 0 15rpx 40rpx rgba(52, 38, 32, 0.27);
  transition: transform 0.15s ease;
}
.cart-float--pressed {
  transform: scale(0.98);
}
.cart-float-icon {
  position: relative;
  width: 67rpx;
  height: 67rpx;
  border-radius: 22rpx;
  background: #ef684f;
  font-size: 34rpx;
  line-height: 67rpx;
  text-align: center;
}
.cart-float-icon text {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 26rpx;
  height: 26rpx;
  padding: 0 4rpx;
  border: 3rpx solid #3e332f;
  border-radius: 15rpx;
  box-sizing: border-box;
  background: #fff;
  color: #e35f49;
  font-size: 15rpx;
  line-height: 23rpx;
}
.cart-float-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  margin-left: 15rpx;
}
.cart-float-copy text:first-child {
  font-size: 22rpx;
  font-weight: 700;
}
.cart-float-copy text:last-child {
  color: #bdb3ae;
  font-size: 16rpx;
}
.cart-float-total {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-right: 13rpx;
}
.cart-float-total text:first-child {
  font-size: 27rpx;
  font-weight: 800;
}
.cart-float-total text:last-child {
  margin-top: 2rpx;
  color: #ffc9b9;
  font-size: 17rpx;
}

.flying-dish-card {
  position: fixed;
  z-index: 90;
  display: flex;
  align-items: center;
  padding: 9rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.95);
  border-radius: 26rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.97);
  box-shadow: 0 9rpx 22rpx rgba(115, 61, 42, 0.2);
  transform: translate3d(0, 0, 0);
  transform-origin: 50% 50%;
  backface-visibility: hidden;
  will-change: transform, opacity;
  animation: card-fly 1.7s cubic-bezier(0.2, 0.72, 0.24, 1) forwards;
  pointer-events: none;
}
.flying-card-art {
  width: 86rpx;
  height: 100%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border-radius: 19rpx;
}
.flying-card-art text {
  font-size: 53rpx;
}
.flying-food-image {
  width: 78rpx;
  height: 78rpx;
  filter: drop-shadow(0 8rpx 8rpx rgba(106, 64, 37, 0.12));
}
.flying-card-copy {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  margin-left: 12rpx;
}
.flying-card-copy text:first-child {
  overflow: hidden;
  color: #493832;
  font-size: 20rpx;
  line-height: 1.25;
  font-weight: 750;
  white-space: nowrap;
  text-overflow: ellipsis;
}
.flying-card-copy text:last-child {
  margin-top: 7rpx;
  color: #ad8c80;
  font-size: 16rpx;
  line-height: 1;
  white-space: nowrap;
}
.flying-card-heart {
  position: absolute;
  right: -10rpx;
  top: -12rpx;
  width: 37rpx;
  height: 37rpx;
  border: 3rpx solid #fff;
  border-radius: 50%;
  background: #ef6b56;
  color: #fff;
  font-size: 18rpx;
  line-height: 37rpx;
  text-align: center;
  box-shadow: 0 5rpx 12rpx rgba(197, 75, 55, 0.22);
}
@keyframes card-fly {
  from {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1) rotate(0deg);
  }
  to {
    opacity: 0;
    transform: translate3d(var(--fly-end-x), var(--fly-end-y), 0) scale(0.08)
      rotate(var(--fly-end-rotate));
  }
}

.family-overlay {
  position: fixed;
  z-index: 115;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 42rpx;
  box-sizing: border-box;
  background: rgba(49, 35, 30, 0.48);
  animation: fade-in 0.2s ease both;
}
.family-card {
  position: relative;
  width: 100%;
  min-height: 520rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 56rpx 38rpx 36rpx;
  border-radius: 38rpx;
  box-sizing: border-box;
  background: #fffaf7;
  box-shadow: 0 24rpx 70rpx rgba(49, 31, 24, 0.25);
  animation: dialog-in 0.24s ease both;
  max-height: 90vh;
  overflow-y: auto;
}
.family-card-close {
  position: absolute;
  right: 22rpx;
  top: 22rpx;
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  background: #f1e8e3;
  color: #8e7f78;
  font-size: 37rpx;
  line-height: 51rpx;
  text-align: center;
}
.family-cloud-icon {
  width: 104rpx;
  height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 35rpx;
  background: linear-gradient(145deg, #ffe9dc, #f6b39a);
  color: #e55f49;
  font-size: 49rpx;
  box-shadow: 0 12rpx 28rpx rgba(195, 92, 62, 0.16);
}
.family-cloud-icon.is-loading {
  color: #6796b2;
  background: #e8f3fa;
  animation: cloud-breathe 1.2s ease-in-out infinite alternate;
}
.family-cloud-icon.is-offline {
  color: #948680;
  background: #eee9e6;
