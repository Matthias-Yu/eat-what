  align-items: center;
  padding: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 28rpx;
  box-sizing: border-box;
  background: linear-gradient(170deg, #ffffff, #fffaf6);
  box-shadow:
    0 10rpx 26rpx rgba(80, 50, 36, 0.05),
