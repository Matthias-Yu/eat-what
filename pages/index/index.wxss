  text-align: center;
}
.category-scroll {
  width: calc(100% + 30rpx);
  margin: 0 -30rpx 28rpx 0;
}
.category-row {
  display: flex;
  gap: 14rpx;
  padding-right: 30rpx;
}
.category-pill {
  flex: 0 0 auto;
  height: 66rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 0 22rpx;
  border: 1rpx solid #eee2db;
  border-radius: 33rpx;
  background: #fff;
  color: #8e7d75;
  font-size: 22rpx;
  font-weight: 600;
  box-sizing: border-box;
}
.category-pill.is-active {
  border-color: #ef684f;
  background: #ef684f;
  color: #fff;
  box-shadow: 0 8rpx 20rpx rgba(222, 92, 67, 0.2);
}
.food-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}
.food-card {
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 30rpx;
  background: linear-gradient(170deg, #ffffff, #fffaf6);
  box-shadow:
    0 12rpx 28rpx rgba(77, 46, 34, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  transition: transform 0.2s ease;
}
.food-card:active {
  transform: translateY(2rpx);
}
.food-art {
  position: relative;
  height: 196rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.food-art-glow {
  position: absolute;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.38);
}
.food-image {
  position: relative;
  z-index: 1;
  width: 174rpx;
  height: 174rpx;
  filter: drop-shadow(0 14rpx 14rpx rgba(106, 64, 37, 0.14));
}
.food-emoji {
  position: relative;
  z-index: 1;
  font-size: 102rpx;
  filter: drop-shadow(0 10rpx 10rpx rgba(106, 64, 37, 0.12));
}
.recommend-mark {
  position: absolute;
  z-index: 2;
  top: 14rpx;
  left: 14rpx;
  padding: 7rpx 13rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.9);
  color: #e6654e;
  font-size: 17rpx;
  font-weight: 700;
}
.food-info {
  position: relative;
  min-height: 142rpx;
  padding: 16rpx 66rpx 17rpx 17rpx;
  box-sizing: border-box;
}
.food-name {
  display: block;
  overflow: hidden;
  font-size: 25rpx;
  font-weight: 750;
  white-space: nowrap;
  text-overflow: ellipsis;
}
.food-desc {
  display: block;
  overflow: hidden;
  margin-top: 7rpx;
  color: #a1918a;
  font-size: 19rpx;
  white-space: nowrap;
  text-overflow: ellipsis;
}
.food-tags {
  display: flex;
  gap: 7rpx;
  margin-top: 10rpx;
}
.food-tags text {
  padding: 4rpx 9rpx;
  border-radius: 9rpx;
  background: #fff3ed;
  color: #da795e;
  font-size: 16rpx;
}
.add-button {
  width: 52rpx;
  height: 52rpx;
  font-size: 34rpx;
}
.food-info > .add-button {
  position: absolute;
  right: 15rpx;
  bottom: 16rpx;
}
.menu-empty,
.todo-empty {
  min-height: 560rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.empty-art {
  width: 150rpx;
  height: 150rpx;
  margin-bottom: 22rpx;
  border-radius: 50%;
  background: #fff0e7;
  font-size: 74rpx;
  line-height: 150rpx;
  text-align: center;
}
.empty-title {
  color: #4b3d37;
  font-size: 28rpx;
  font-weight: 750;
}
.empty-subtitle {
  margin-top: 10rpx;
  color: #aa9b94;
  font-size: 21rpx;
}
.menu-empty button {
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 25rpx;
  padding: 0 28rpx;
  border-radius: 34rpx;
  background: #ef684f;
  color: #fff;
  font-size: 21rpx;
  line-height: 1;
}

/* Todo */
.todo-date-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  border: 8rpx solid #f6c7b9;
  background: #fff;
  color: #e86149;
  font-size: 25rpx;
  line-height: 62rpx;
  text-align: center;
  font-weight: 800;
  box-sizing: border-box;
}
.todo-date-icon text {
  font-size: 14rpx;
}
.progress-card {
  padding: 28rpx;
  border-radius: 31rpx;
  background: linear-gradient(135deg, #fff0e6, #ffe4d7);
  box-shadow: 0 10rpx 30rpx rgba(184, 104, 72, 0.09);
}
.progress-title {
  display: block;
  color: #533b32;
  font-size: 27rpx;
  font-weight: 750;
}
.progress-copy {
  display: block;
  margin-top: 7rpx;
  color: #a77868;
  font-size: 20rpx;
}
.progress-sun {
  width: 58rpx;
  height: 58rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.6);
  color: #e98158;
  font-size: 30rpx;
  line-height: 58rpx;
  text-align: center;
}
.progress-track {
  height: 12rpx;
  overflow: hidden;
  margin-top: 24rpx;
  border-radius: 6rpx;
  background: rgba(219, 142, 111, 0.2);
}
.progress-fill {
  height: 100%;
  min-width: 2%;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #f1845e, #eb5f49);
  transition: width 0.35s ease;
}
.todo-toolbar {
  margin: 33rpx 0 20rpx;
}
.filter-tabs {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx;
  border-radius: 24rpx;
  background: #f5ede7;
}
.filter-tabs text {
  height: 51rpx;
  padding: 0 17rpx;
  border-radius: 19rpx;
  color: #9c8d86;
  font-size: 19rpx;
  line-height: 51rpx;
  font-weight: 600;
}
.filter-tabs text.is-active {
  background: #fff;
  color: #e8664d;
  box-shadow: 0 4rpx 13rpx rgba(80, 46, 32, 0.08);
}
.toolbar-hint {
  color: #b8aaa4;
  font-size: 18rpx;
}
.todo-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.todo-item {
  min-height: 142rpx;
  display: flex;
  align-items: flex-start;
  padding: 24rpx 20rpx;
  border: 1rpx solid #f0e5de;
  border-radius: 27rpx;
  box-sizing: border-box;
  background: #fff;
  box-shadow: 0 7rpx 22rpx rgba(75, 45, 34, 0.045);
  transition: transform 0.15s ease;
}
.todo-item--pressed {
  transform: scale(0.985);
}
.todo-checkbox {
  width: 42rpx;
  height: 42rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 2rpx;
  border: 3rpx solid #e9a08c;
  border-radius: 50%;
  box-sizing: border-box;
  color: #fff;
  font-size: 24rpx;
}
.todo-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  margin: 0 17rpx;
}
.todo-title {
  font-size: 25rpx;
  font-weight: 700;
}
.todo-note {
  margin-top: 6rpx;
  color: #9c8b84;
  font-size: 19rpx;
}
.todo-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 13rpx;
}
.todo-category {
  padding: 4rpx 11rpx;
  border-radius: 11rpx;
  background: #f2edfb;
  color: #836bb7;
  font-size: 17rpx;
}
.category-housework {
  background: #e9f5ef;
  color: #578e75;
}
.category-shopping {
  background: #fff1e3;
  color: #d9834f;
}
.category-work {
  background: #e9f0fa;
  color: #6681a5;
}
.todo-due {
  color: #b09f97;
  font-size: 17rpx;
}
.todo-more {
  color: #c4b5ae;
  font-size: 27rpx;
  letter-spacing: 2rpx;
}
.todo-item.is-completed {
  background: rgba(255, 255, 255, 0.58);
  box-shadow: none;
}
.todo-item.is-completed .todo-checkbox {
  border-color: #7fb299;
  background: #7fb299;
}
.todo-item.is-completed .todo-title {
  color: #a99b94;
  text-decoration: line-through;
}
.todo-item.is-completed .todo-note {
  color: #bdb2ad;
}
.todo-empty {
  min-height: 450rpx;
}
.new-todo-button {
  height: 82rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 28rpx 0 0;
  padding: 0;
  border-radius: 27rpx;
  background: linear-gradient(135deg, #f17a5d, #e95e48);
  color: #fff;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 700;
  box-shadow: 0 13rpx 28rpx rgba(218, 87, 62, 0.2);
}
.new-todo-button text {
  margin-right: 8rpx;
  font-size: 31rpx;
  line-height: 1;
}

/* Wishlist */
.wishlist-page {
  background: linear-gradient(
    180deg,
    rgba(234, 247, 241, 0.55),
    transparent 420rpx
  );
}
.wishlist-hero-card {
  position: relative;
  min-height: 260rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 34rpx 30rpx;
  border-radius: 31rpx;
  box-sizing: border-box;
  background: linear-gradient(135deg, #5b9f83 0%, #78b698 58%, #e99b83 100%);
  color: #fff;
  box-shadow: 0 16rpx 36rpx rgba(72, 132, 105, 0.22);
}
.wishlist-hero-card::after {
  content: "";
  position: absolute;
  right: -50rpx;
  bottom: -70rpx;
  width: 240rpx;
  height: 240rpx;
  border: 28rpx solid rgba(255, 255, 255, 0.16);
  border-radius: 50%;
}
.wishlist-hero-copy {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
}
.wishlist-hero-copy .page-kicker {
  color: rgba(255, 255, 255, 0.78);
}
.wishlist-title {
  margin-top: 7rpx;
  font-size: 45rpx;
  line-height: 1.18;
  font-weight: 800;
}
.wishlist-subtitle {
  margin-top: 11rpx;
  font-size: 21rpx;
  opacity: 0.82;
}
.wishlist-hero-mark {
  position: relative;
  z-index: 1;
  width: 112rpx;
  height: 112rpx;
  border: 8rpx solid rgba(255, 255, 255, 0.75);
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  font-size: 64rpx;
  line-height: 100rpx;
  text-align: center;
  box-sizing: border-box;
  transform: rotate(-8deg);
}
.wishlist-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 22rpx;
}
.wishlist-stats view {
  min-height: 102rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 18rpx;
  border: 1rpx solid #e2f0e8;
  border-radius: 24rpx;
  box-sizing: border-box;
  background: #fff;
}
.wishlist-stats text:first-child {
  color: #4f8f72;
  font-size: 34rpx;
  font-weight: 800;
}
.wishlist-stats text:last-child {
  margin-top: 4rpx;
  color: #8d9b91;
  font-size: 18rpx;
}
.wishlist-action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin: 34rpx 0 18rpx;
}
.wishlist-action-row > view:first-child {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
}
.new-wish-button {
  width: 58rpx;
  height: 52rpx;
  flex: 0 0 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  background: #4f9878;
  color: #fff;
  font-size: 32rpx;
  line-height: 52rpx;
  font-weight: 700;
  box-shadow: 0 7rpx 15rpx rgba(70, 139, 108, 0.14);
}
.new-wish-button--pressed {
  transform: scale(0.96);
  opacity: 0.9;
}
.wish-card-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}
.wish-card {
  position: relative;
  overflow: hidden;
  min-height: 210rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 30rpx;
  box-sizing: border-box;
  background: linear-gradient(170deg, #ffffff, #f9fdfb);
  box-shadow:
    0 12rpx 30rpx rgba(56, 105, 84, 0.08),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  transition: transform 0.18s ease;
}
.wish-card::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  width: 9rpx;
  height: 100%;
  background: linear-gradient(180deg, #5fa984, #ef9278);
}
.wish-card--pressed {
  transform: scale(0.985);
}
.wish-card-top,
.wish-card-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.wish-card-stamp {
  width: 54rpx;
  height: 54rpx;
  border-radius: 19rpx;
  background: #eef8f1;
  color: #5d9d7b;
  font-size: 31rpx;
  line-height: 54rpx;
  text-align: center;
  font-weight: 800;
}
.wish-status {
  padding: 7rpx 14rpx;
  border-radius: 16rpx;
  background: #fff0e9;
  color: #e16d52;
  font-size: 17rpx;
  font-weight: 700;
}
.wish-card-title {
  display: block;
  margin-top: 19rpx;
  color: #32443c;
  font-size: 28rpx;
  line-height: 1.35;
  font-weight: 800;
}
.wish-card-note {
  display: block;
  margin-top: 9rpx;
  color: #87968e;
  font-size: 20rpx;
  line-height: 1.55;
}
.wish-card-bottom {
  margin-top: 24rpx;
}
.wish-card-bottom > text {
  color: #9aa7a0;
  font-size: 18rpx;
}
.wish-card-bottom button {
  width: 126rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  border-radius: 20rpx;
  background: #edf7f1;
  color: #579273;
  font-size: 20rpx;
  line-height: 1;
  font-weight: 700;
}
.wish-card.is-realized {
  background: rgba(255, 255, 255, 0.68);
  box-shadow: none;
}
.wish-card.is-realized::before {
  background: #a8c7b7;
}
.wish-card.is-realized .wish-card-stamp {
  background: #e7f3eb;
  color: #6b9d80;
}
.wish-card.is-realized .wish-status {
  background: #edf7f1;
  color: #6b9d80;
}
.wish-card.is-realized .wish-card-title {
  color: #8c9b93;
  text-decoration: line-through;
}
.wish-page-empty {
  min-height: 420rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1rpx dashed #cfe3d7;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.58);
}
.wish-page-empty view {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: #edf7f1;
  color: #5f9b7b;
  font-size: 58rpx;
  line-height: 110rpx;
  text-align: center;
}
.wish-page-empty > text {
  margin-top: 18rpx;
  color: #82948b;
  font-size: 22rpx;
}
.wish-page-empty button {
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 22rpx;
  padding: 0 28rpx;
  border-radius: 23rpx;
  background: #4f9878;
  color: #fff;
  font-size: 21rpx;
  line-height: 1;
  font-weight: 700;
}

/* Profile */
.profile-hero {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 18rpx 0 34rpx;
}
.profile-avatar {
  position: relative;
  width: 142rpx;
  height: 142rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 7rpx solid #fff;
  border-radius: 50%;
  box-sizing: border-box;
  background: linear-gradient(145deg, #ffe5d6, #f7ad91);
  color: #d96d50;
  font-size: 67rpx;
  box-shadow: 0 15rpx 35rpx rgba(174, 88, 56, 0.16);
}
.profile-avatar view {
  position: absolute;
  right: -4rpx;
  bottom: 6rpx;
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #fff;
  border-radius: 50%;
  background: #ed6551;
  color: #fff;
  font-size: 20rpx;
  line-height: 40rpx;
  text-align: center;
}
.profile-title {
  margin-top: 18rpx;
  font-size: 35rpx;
  font-weight: 800;
}
.profile-subtitle {
  margin-top: 5rpx;
  color: #a79790;
  font-size: 21rpx;
}
.profile-bubble {
  position: absolute;
  color: #e9957d;
}
.bubble-one {
  left: 90rpx;
  top: 60rpx;
  font-size: 34rpx;
  transform: rotate(-18deg);
}
.bubble-two {
  right: 95rpx;
  top: 30rpx;
  color: #edc35f;
  font-size: 28rpx;
}
.stats-card {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 27rpx 10rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 30rpx;
  background: linear-gradient(170deg, #ffffff, #fffaf6);
  box-shadow:
    0 12rpx 30rpx rgba(77, 45, 32, 0.06),
