page {
  height: 100%;
  overflow: hidden;
  background:
    radial-gradient(
      circle at 100% 0,
      rgba(255, 216, 190, 0.28),
      transparent 38%
    ),
    radial-gradient(
      circle at 0 18%,
      rgba(255, 228, 214, 0.22),
      transparent 30%
    ),
    radial-gradient(
      circle at 50% 120%,
      rgba(255, 234, 210, 0.3),
      transparent 45%
    ),
    #fffaf5;
}

.page-scroll {
  height: calc(100vh - 44px - env(safe-area-inset-top));
}

.page {
  min-height: 100%;
  padding: 18rpx 30rpx calc(250rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.home-top,
.page-header,
.section-heading,
.mini-food-bottom,
.progress-top,
.todo-toolbar,
.sheet-header,
.checkout-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.home-top {
  margin-bottom: 26rpx;
}

.home-actions {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 6rpx;
}

.eyebrow {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #40332e;
  font-size: 38rpx;
  line-height: 1.4;
  font-weight: 800;
  letter-spacing: -1rpx;
}

.eyebrow text:first-child {
  font-size: 32rpx;
}

.date-label {
  display: block;
  margin-top: 4rpx;
  color: #a3938c;
  font-size: 23rpx;
}

.avatar {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  padding: 5rpx;
  border-radius: 50%;
  box-sizing: border-box;
  background: linear-gradient(145deg, #ffd6c4, #f4a284);
  box-shadow: 0 8rpx 20rpx rgba(219, 112, 78, 0.2);
}

.avatar-face {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #fff;
  border-radius: 50%;
  box-sizing: border-box;
  background: #fff0e8;
  color: #e88667;
  font-size: 38rpx;
  font-weight: 700;
}

.avatar-heart {
  position: absolute;
  right: -2rpx;
  bottom: -2rpx;
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid #fff;
  border-radius: 50%;
  background: #ee6652;
  color: #fff;
  font-size: 16rpx;
  line-height: 28rpx;
  text-align: center;
}

.hero-swiper {
  height: 350rpx;
  background: transparent;
}
.hero-swiper-item {
  box-sizing: border-box;
  display: flex;
  align-items: flex-start;
  padding: 0 8rpx;
  background: transparent;
}

.hero-card {
  position: relative;
  width: 100%;
  height: 350rpx;
  overflow: hidden;
  padding: 38rpx 30rpx;
  border-radius: 38rpx;
  box-sizing: border-box;
  background:
    radial-gradient(
      circle at 18% 0,
      rgba(255, 255, 255, 0.18),
      transparent 42%
    ),
    linear-gradient(135deg, #f5895f 0%, #ec5a47 56%, #d6443a 100%);
  box-shadow: none;
  color: #fff;
}
/* 新品卡：浅色 tone 背景（同 mini 卡）+ 深棕字，文字加白色描边保证任何浅 tone 下清晰 */
.hero-card--new {
  color: #4a3326;
  box-shadow: none;
}
.hero-card--new .hero-copy {
  text-shadow:
    0 0 4rpx rgba(255, 255, 255, 0.85),
    0 1rpx 2rpx rgba(255, 255, 255, 0.9);
}
.hero-card--new .hero-glow {
  background: rgba(255, 255, 255, 0.4);
}
.hero-card--new .hero-subtitle {
  opacity: 0.78;
}
.hero-card--new .hero-button {
  background: #4a3326;
  color: #fff;
}
.hero-card--new .hero-plate.has-image .hero-plate-image {
  filter: drop-shadow(0 16rpx 26rpx rgba(80, 55, 35, 0.28));
}

.hero-glow {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.11);
}

.hero-glow-one {
  width: 310rpx;
  height: 310rpx;
  right: -80rpx;
  top: -100rpx;
}
.hero-glow-two {
  width: 160rpx;
  height: 160rpx;
  left: 290rpx;
  bottom: -110rpx;
}
.hero-copy {
  position: relative;
  z-index: 2;
  width: 56%;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.hero-kicker {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 10rpx;
  font-size: 22rpx;
  font-weight: 600;
  opacity: 0.9;
}

.hero-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #ffe49a;
}
.hero-dot--new {
  background: #4a3326;
}
.hero-title {
  display: block;
  font-size: 48rpx;
  line-height: 1.12;
  font-weight: 800;
  letter-spacing: 2rpx;
}
.hero-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 20rpx;
  opacity: 0.78;
  white-space: nowrap;
}

.hero-button {
  align-self: flex-start;
  width: auto;
  min-width: 150rpx;
  max-width: 100%;
  height: 62rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin: 22rpx 0 0;
  padding: 0 34rpx;
  box-sizing: border-box;
  border-radius: 31rpx;
  background: #fff;
  color: #e45b45;
  font-size: 23rpx;
  line-height: 1;
  font-weight: 700;
  box-shadow: 0 8rpx 20rpx rgba(140, 40, 28, 0.16);
  transition: transform 0.24s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.hero-button text {
  margin-left: 8rpx;
  line-height: 1;
}
.button-pressed {
  transform: scale(0.94);
  opacity: 0.9;
}

.hero-art {
  position: absolute;
  z-index: 1;
  right: -6rpx;
  bottom: 5rpx;
  width: 300rpx;
  height: 300rpx;
}

.hero-plate {
  position: absolute;
  right: 10rpx;
  bottom: 28rpx;
  width: 264rpx;
  height: 210rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 10rpx solid rgba(255, 244, 229, 0.92);
  border-radius: 50%;
  box-sizing: border-box;
  background: #ffc065;
  box-shadow: 0 18rpx 35rpx rgba(122, 34, 25, 0.23);
  font-size: 130rpx;
  transform: rotate(-7deg);
  overflow: hidden;
}
.hero-plate-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  transform: rotate(7deg) scale(1.12);
}
.hero-plate.has-image {
  width: 330rpx;
  height: 330rpx;
  right: -6rpx;
  bottom: 0;
  border: none;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
  transform: none;
  overflow: visible;
}
.hero-plate.has-image .hero-plate-image {
  border-radius: 0;
  transform: none;
  filter: drop-shadow(0 16rpx 26rpx rgba(122, 34, 25, 0.32));
}

/* 菜品上方的动态雾气 */
.hero-mist {
  position: absolute;
  z-index: 2;
  right: 86rpx;
  top: 38rpx;
  width: 150rpx;
  height: 150rpx;
  pointer-events: none;
}
.mist {
  position: absolute;
  bottom: 0;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.6);
  filter: blur(4rpx);
  opacity: 0;
  will-change: transform, opacity;
  animation: mist-rise 5s ease-in-out infinite;
}
.mist-one {
  left: 30rpx;
  animation-delay: 0s;
}
.mist-two {
  left: 66rpx;
  animation-delay: 1.1s;
}
.mist-three {
  left: 100rpx;
  animation-delay: 2.2s;
}
@keyframes mist-rise {
  0% {
    transform: translateY(0) scale(0.7);
    opacity: 0;
  }
  20% {
    opacity: 0.75;
  }
  60% {
    opacity: 0.5;
  }
  100% {
    transform: translateY(-110rpx) scale(2.4);
    opacity: 0;
  }
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
  margin: 30rpx 0 42rpx;
}

.quick-item {
  position: relative;
  height: 142rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 28rpx;
  background: linear-gradient(160deg, #ffffff, #fff6ef);
  box-shadow:
    0 10rpx 28rpx rgba(84, 51, 38, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  font-size: 21rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
  transition:
    transform 0.22s cubic-bezier(0.34, 1.56, 0.64, 1),
    box-shadow 0.22s ease;
}

.quick-item--pressed {
  transform: translateY(3rpx) scale(0.96);
  box-shadow: 0 4rpx 14rpx rgba(84, 51, 38, 0.08);
}
.quick-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 22rpx;
  font-size: 32rpx;
  line-height: 64rpx;
  text-align: center;
  font-weight: 800;
  box-shadow: inset 0 -3rpx 8rpx rgba(120, 70, 50, 0.06);
}
.quick-orange {
  color: #e76447;
  background: linear-gradient(150deg, #fff2e9, #ffe2d2);
}
.quick-purple {
  color: #8e74c7;
  background: linear-gradient(150deg, #f3effc, #e9e1fb);
}
.quick-green {
  color: #5b9f83;
  background: linear-gradient(150deg, #ecf8f2, #ddf2e8);
}
.quick-pink {
  color: #dc7184;
  background: linear-gradient(150deg, #fff1f3, #ffe0e6);
}
.quick-badge {
  position: absolute;
  top: 12rpx;
  right: 15rpx;
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 5rpx;
  border-radius: 16rpx;
  box-sizing: border-box;
  background: #ef604a;
  color: #fff;
  font-size: 17rpx;
  line-height: 28rpx;
  text-align: center;
}

.farm-entry-orb {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  overflow: visible;
  padding: 5rpx;
  border-radius: 50%;
  box-sizing: border-box;
  background: linear-gradient(145deg, #ffd6c4, #f4a284);
  box-shadow: 0 8rpx 20rpx rgba(219, 112, 78, 0.2);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.farm-entry-orb--pressed {
  transform: translateY(3rpx) scale(0.96);
  box-shadow: 0 4rpx 12rpx rgba(219, 112, 78, 0.14);
}
.farm-entry-face {
  width: 100%;
  height: 100%;
  overflow: hidden;
  border: 4rpx solid #fff;
  border-radius: 50%;
  box-sizing: border-box;
  background: #fff0e8;
}
.farm-entry-image {
  width: 100%;
  height: 100%;
  display: block;
  transform: scale(1.22);
}
.farm-entry-badge {
  position: absolute;
  top: -7rpx;
  right: -7rpx;
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 7rpx;
  border: 3rpx solid #fff;
  border-radius: 999rpx;
  box-sizing: border-box;
  background: #ef604a;
  color: #fff;
  font-size: 17rpx;
  font-weight: 800;
  line-height: 24rpx;
  text-align: center;
}

.section-heading {
  margin-bottom: 20rpx;
}
.section-heading > view:first-child {
  display: flex;
  flex-direction: column;
}
.section-title {
  position: relative;
  padding-left: 20rpx;
  color: #3c302c;
  font-size: 31rpx;
  font-weight: 800;
  letter-spacing: -0.5rpx;
}
.section-title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 50%;
  width: 8rpx;
  height: 30rpx;
  transform: translateY(-50%);
  border-radius: 6rpx;
  background: linear-gradient(180deg, #f7905f, #ec5a45);
}
.section-subtitle {
  margin-top: 6rpx;
  padding-left: 20rpx;
  color: #a69891;
  font-size: 20rpx;
}
.section-more {
  color: #e4674f;
  font-size: 22rpx;
  font-weight: 600;
}
.recommend-scroll {
  width: calc(100% + 30rpx);
  margin-right: -30rpx;
}
.recommend-row {
  display: flex;
  gap: 18rpx;
  padding-right: 30rpx;
}

.mini-food-card {
  flex: 0 0 244rpx;
  overflow: hidden;
  padding-bottom: 20rpx;
  border: 1rpx solid rgba(120, 80, 50, 0.1);
  border-radius: 30rpx;
  box-sizing: border-box;
  background: #ffffff;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  transition: transform 0.22s ease;
}
.mini-food-card:active {
  transform: translateY(2rpx);
}

.mini-food-art {
  position: relative;
  height: 172rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  font-size: 92rpx;
}
.mini-food-image {
  position: relative;
  z-index: 1;
  width: 160rpx;
  height: 160rpx;
}
.food-tag {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 5rpx 12rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.88);
  color: #de624c;
  font-size: 17rpx;
  font-weight: 600;
}
.mini-food-name {
  display: block;
  overflow: hidden;
  margin: 0 18rpx;
  font-size: 24rpx;
  font-weight: 700;
  white-space: nowrap;
  text-overflow: ellipsis;
}
.mini-food-bottom {
  margin: 10rpx 16rpx 0 18rpx;
}
.mini-food-hint {
  color: #b08e82;
  font-size: 18rpx;
  font-weight: 600;
}
.add-mini,
.add-button {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #ef654d;
  color: #fff;
  box-shadow: 0 6rpx 15rpx rgba(225, 91, 67, 0.25);
  font-weight: 500;
  transition: transform 0.24s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.add-mini {
  width: 46rpx;
  height: 46rpx;
  font-size: 29rpx;
}
.add-pressed {
  transform: scale(0.84) rotate(12deg);
}
.tone-sunset {
  background: linear-gradient(145deg, #ffe7dc, #ffc1a8);
}
.tone-honey {
  background: linear-gradient(145deg, #fff2ce, #ffd48a);
}
.tone-lemon {
  background: linear-gradient(145deg, #fff8d8, #f7e69e);
}
.tone-mint {
  background: linear-gradient(145deg, #eaf8e7, #bfe6c6);
}
.tone-cream {
  background: linear-gradient(145deg, #fff5e7, #ead6bc);
}
.tone-blush {
  background: linear-gradient(145deg, #fff0f3, #f5cbd5);
}

.todo-heading {
  margin-top: 42rpx;
}
.home-todo-card {
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 30rpx;
  background: linear-gradient(170deg, #ffffff, #fffaf6);
  box-shadow:
    0 12rpx 30rpx rgba(80, 50, 36, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}
.home-todo-row {
  min-height: 116rpx;
  display: flex;
  align-items: center;
  padding: 0 22rpx;
  border-bottom: 1rpx solid #f6eee9;
  box-sizing: border-box;
}
.home-todo-row:last-child {
  border-bottom: 0;
}
.todo-check-small {
  width: 34rpx;
  height: 34rpx;
  flex-shrink: 0;
  border: 3rpx solid #ed9a85;
  border-radius: 50%;
  box-sizing: border-box;
}
.home-todo-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-left: 18rpx;
}
.home-todo-title {
  font-size: 24rpx;
  font-weight: 650;
}
.home-todo-meta {
  color: #aa9a92;
  font-size: 19rpx;
}
.todo-arrow {
  color: #c6b8b1;
  font-size: 34rpx;
}
.home-empty {
  height: 130rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: #9c8b83;
  font-size: 22rpx;
}
.home-empty-icon {
  color: #ee876f;
}
.love-note {
  margin-top: 35rpx;
  color: #c7aaa0;
  font-size: 20rpx;
  text-align: center;
  letter-spacing: 1rpx;
}

/* Menu */
.page-header {
  margin: 2rpx 0 28rpx;
}
.page-header > view:first-child {
  display: flex;
  flex-direction: column;
}
.page-kicker {
  color: #e8775f;
  font-size: 17rpx;
  font-weight: 800;
  letter-spacing: 3rpx;
}
.page-title {
  margin-top: 5rpx;
  color: #382d29;
  font-size: 44rpx;
  line-height: 1.25;
  font-weight: 800;
  letter-spacing: -2rpx;
}
.header-cart {
