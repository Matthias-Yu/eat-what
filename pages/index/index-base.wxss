page {
  height: 100%;
  overflow: hidden;
  background:
    radial-gradient(
      circle at 100% 0,
      rgba(255, 216, 190, 0.28),
      transparent 38%
    ),
    radial-gradient(
      circle at 0 18%,
      rgba(255, 228, 214, 0.22),
      transparent 30%
    ),
    radial-gradient(
      circle at 50% 120%,
      rgba(255, 234, 210, 0.3),
      transparent 45%
    ),
    #fffaf5;
}

.page-scroll {
  position: relative;
  z-index: 1;
  height: calc(100vh - 44px - env(safe-area-inset-top));
}

.image-boot-screen {
  position: fixed;
  inset: 0;
  z-index: 10000;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background:
    radial-gradient(circle at 50% 42%, rgba(255, 224, 202, 0.52), transparent 30%),
    #fffaf2;
  color: #8d7464;
  font-size: 24rpx;
  letter-spacing: 3rpx;
}

.home-loader {
  position: relative;
  width: 220rpx;
  height: 205rpx;
  animation: image-boot-breathe 1.45s ease-in-out infinite;
}
.home-loader-image {
  position: absolute;
  inset: 8rpx;
  z-index: 2;
  width: 204rpx;
  height: 189rpx;
  filter: drop-shadow(0 12rpx 14rpx rgba(157, 98, 67, 0.12));
}
.home-loader-glow {
  position: absolute;
  inset: 18rpx 10rpx 3rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 213, 174, 0.56), rgba(255, 229, 205, 0) 68%);
  animation: home-loader-glow 1.45s ease-in-out infinite;
}
.home-loader-orbit {
  position: absolute;
  inset: -7rpx;
  z-index: 3;
  animation: home-loader-orbit 2.4s linear infinite;
}
.home-loader-orbit text {
  position: absolute;
  top: 2rpx;
  left: 101rpx;
  color: #ef765f;
  font-size: 20rpx;
  filter: drop-shadow(0 2rpx 3rpx rgba(218, 103, 80, 0.16));
}
.home-loader-spark {
  position: absolute;
  z-index: 4;
  color: #e6b36e;
  animation: home-loader-spark 1.3s ease-in-out infinite;
}
.home-loader-spark--one {
  top: 34rpx;
  left: 4rpx;
  font-size: 20rpx;
}
.home-loader-spark--two {
  right: 4rpx;
  bottom: 46rpx;
  font-size: 15rpx;
  animation-delay: 0.45s;
}
.image-boot-copy {
  margin-top: 12rpx;
}
.image-boot-dots {
  display: flex;
  gap: 10rpx;
  margin-top: 15rpx;
}
.image-boot-dots text {
  width: 9rpx;
  height: 9rpx;
  border-radius: 50%;
  background: #d99a81;
  animation: image-boot-dot 1.05s ease-in-out infinite;
}
.image-boot-dots text:nth-child(2) { animation-delay: 0.14s; }
.image-boot-dots text:nth-child(3) { animation-delay: 0.28s; }
.image-boot-retry {
  height: 58rpx;
  margin-top: 24rpx;
  padding: 0 28rpx;
  border: 1rpx solid rgba(192, 125, 98, 0.24);
  border-radius: 29rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #b66f58;
  font-size: 21rpx;
  line-height: 58rpx;
}

.family-menu-icon.is-game {
  background: #fff0c9;
  color: #b27b25;
}

.deal-overlay {
  position: fixed;
  inset: 0;
  z-index: 12000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 36rpx 28rpx;
  box-sizing: border-box;
  background: rgba(39, 31, 24, 0.72);
}
.deal-game {
  width: 100%;
  max-height: 92vh;
  overflow-y: auto;
  padding: 30rpx 28rpx 32rpx;
  border: 2rpx solid rgba(211, 168, 83, 0.42);
  border-radius: 34rpx;
  box-sizing: border-box;
  background: linear-gradient(165deg, #fffaf0, #f8ead0);
}
.deal-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}
.deal-kicker,
.deal-title { display: block; }
.deal-kicker { color: #b18a4e; font-size: 14rpx; font-weight: 800; letter-spacing: 3rpx; }
.deal-title { margin-top: 6rpx; color: #473728; font-size: 38rpx; font-weight: 820; }
.deal-close { width: 54rpx; height: 54rpx; border-radius: 50%; background: rgba(91, 69, 43, 0.08); color: #766044; font-size: 35rpx; line-height: 50rpx; text-align: center; }
.deal-guide { display: block; margin: 17rpx 0; color: #806c55; font-size: 21rpx; font-weight: 650; }
.deal-prize-board { display: grid; grid-template-columns: 1fr 1fr; gap: 13rpx; margin-bottom: 24rpx; }
.deal-prize-column { min-height: 150rpx; padding: 14rpx; border: 1rpx solid rgba(120,98,67,.14); border-radius: 18rpx; background: rgba(255,255,255,.42); }
.deal-prize-column.is-unopened { border-color: rgba(203,151,50,.25); background: rgba(255,249,224,.62); }
.deal-prize-heading { display: flex; align-items: center; justify-content: space-between; margin-bottom: 11rpx; color: #8c785e; font-size: 17rpx; font-weight: 750; }
.deal-prize-heading text:last-child { min-width: 30rpx; height: 30rpx; border-radius: 15rpx; background: rgba(98,78,52,.08); font-size: 14rpx; line-height: 30rpx; text-align: center; }
.deal-prize-list { display: flex; flex-wrap: wrap; gap: 7rpx; align-content: flex-start; }
.deal-prize { min-width: 42rpx; padding: 6rpx 8rpx; border-radius: 10rpx; background: rgba(255,255,255,.72); color: #8d7042; font-size: 15rpx; font-weight: 700; text-align: center; }
.is-opened .deal-prize { background: rgba(119,105,86,.09); color: #aaa092; text-decoration: line-through; }
.deal-prize-empty { width: 100%; padding-top: 18rpx; color: #b2a899; font-size: 16rpx; text-align: center; }
.deal-box-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 16rpx 10rpx; }
.deal-box { position: relative; height: 76rpx; display: flex; align-items: center; justify-content: center; border: 2rpx solid #d0a652; border-radius: 13rpx; background: linear-gradient(150deg, #ffe38a, #dba53c); color: #5d421a; font-size: 22rpx; font-weight: 850; transition: transform .16s ease, opacity .16s ease; }
.deal-box-handle { position: absolute; top: -10rpx; left: 50%; width: 34rpx; height: 15rpx; border: 4rpx solid #b8872f; border-bottom: 0; border-radius: 8rpx 8rpx 0 0; transform: translateX(-50%); }
.deal-box--pressed { transform: scale(.95); }
.deal-box.is-chosen { border-color: #dd725c; background: linear-gradient(150deg, #ffc5ac, #e77d62); color: #fff; }
.deal-box.is-opened { border-style: dashed; border-color: rgba(117,96,63,.22); background: rgba(255,255,255,.35); color: #9c7950; opacity: .7; }
.deal-box-value { font-size: 24rpx; }
.deal-own-box { margin-top: 22rpx; padding: 17rpx; border-radius: 17rpx; background: rgba(255,255,255,.55); color: #7a6751; font-size: 19rpx; text-align: center; }
.deal-own-box text { color: #d36f58; font-weight: 800; }
.deal-offer-card,
.deal-result-card { margin-top: 24rpx; padding: 26rpx; border: 2rpx solid rgba(205,157,68,.3); border-radius: 24rpx; background: rgba(255,255,255,.72); text-align: center; }
.deal-offer-card > text,
.deal-result-card > text { display: block; color: #8b7250; font-size: 19rpx; }
.deal-offer-card > view:nth-child(2),
.deal-result-card > view { margin: 7rpx 0 18rpx; color: #b77820; font-size: 52rpx; font-weight: 850; }
.deal-offer-card > view:nth-child(2) text,
.deal-result-card > view text { margin-right: 3rpx; font-size: 24rpx; }
.deal-offer-actions { display: flex; gap: 14rpx; }
.deal-offer-actions button,
.deal-result-card button { height: 66rpx; flex: 1; margin: 0; border-radius: 20rpx; background: #625342; color: #fff; font-size: 21rpx; line-height: 66rpx; }
.deal-offer-actions button:last-child,
.deal-result-card button { background: #d99a3d; }
.deal-result-card button { width: 230rpx; margin: 20rpx auto 0; }
@keyframes home-loader-orbit {
  to { transform: rotate(360deg); }
}
@keyframes home-loader-glow {
  0%, 100% { transform: scale(0.9); opacity: 0.48; }
  50% { transform: scale(1.08); opacity: 0.9; }
}
@keyframes home-loader-spark {
  0%, 100% { transform: scale(0.65) rotate(-8deg); opacity: 0.25; }
  50% { transform: scale(1.12) rotate(8deg); opacity: 1; }
}

@keyframes image-boot-breathe {
  0%, 100% { transform: translateY(3rpx) scale(0.98); }
  50% { transform: translateY(-3rpx) scale(1.02); }
}
@keyframes image-boot-dot {
  0%, 60%, 100% { transform: translateY(0); opacity: 0.35; }
  30% { transform: translateY(-7rpx); opacity: 1; }
}

.tab-image-preload-bank {
  position: fixed;
  top: -4rpx;
  left: -4rpx;
  z-index: -2;
  width: 2rpx;
  height: 2rpx;
  overflow: hidden;
  opacity: 0.01;
  pointer-events: none;
}

.tab-image-preload-bank image {
  width: 2rpx;
  height: 2rpx;
}

.page {
  min-height: 100%;
  padding: 18rpx 30rpx calc(250rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.home-full-bg {
  position: fixed;
  inset: 0;
  z-index: 0;
  width: 100vw;
  height: 100vh;
  opacity: 0;
  filter: saturate(0.96) contrast(0.92) brightness(1.08);
  pointer-events: none;
  transition: opacity 120ms ease-out;
}

.home-full-bg--active {
  opacity: 0.9;
}

.menu-full-bg,
.todo-full-bg {
  position: fixed;
  inset: 0;
  z-index: 0;
  width: 100vw;
  height: 100vh;
  opacity: 0;
  filter: saturate(0.96) contrast(0.92) brightness(1.08);
  pointer-events: none;
  transition: opacity 120ms ease-out;
}

.menu-full-bg--active,
.todo-full-bg--active {
  opacity: 0.88;
}

.wishlist-full-bg {
  position: fixed;
  inset: 0;
  z-index: 0;
  width: 100vw;
  height: 100vh;
  opacity: 0;
  filter: saturate(0.96) contrast(0.92) brightness(1.08);
  pointer-events: none;
  transition: opacity 120ms ease-out;
}

.wishlist-full-bg--active {
  opacity: 0.84;
}

.menu-page {
  position: relative;
  background: transparent;
}

.todo-page {
  position: relative;
  background: transparent;
}

.home-page {
  position: relative;
  background: transparent;
}

.home-page .home-top,
.home-page .anniversary-card,
.home-page .home-letter-arrival,
.home-page .hero-swiper,
.home-page .quick-grid,
.home-page > .section-heading,
.home-page .recommend-scroll,
.home-page .home-todo-card,
.home-page .love-note {
  opacity: 0;
  transform: translateY(18rpx) scale(0.985);
  animation: home-rise-in 0.52s cubic-bezier(0.18, 0.86, 0.3, 1) forwards;
}

.home-page .home-top {
  animation-delay: 0.02s;
}

.home-page .anniversary-card {
  animation-delay: 0.06s;
}

.home-page .home-letter-arrival {
  animation-delay: 0.08s;
}

.home-page .hero-swiper {
  animation-delay: 0.12s;
}

.home-page .quick-grid {
  animation-delay: 0.14s;
}

.home-page > .section-heading {
  animation-delay: 0.18s;
}

.home-page .recommend-scroll {
  animation-delay: 0.22s;
}

.home-page .todo-heading {
  animation-delay: 0.26s;
}

.home-page .home-todo-card {
  animation-delay: 0.3s;
}

.home-page .love-note {
  animation-delay: 0.34s;
}

@keyframes home-rise-in {
  0% {
    opacity: 0;
    transform: translateY(18rpx) scale(0.985);
  }
  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.home-top,
.page-header,
.section-heading,
.mini-food-bottom,
.progress-top,
.todo-toolbar,
.sheet-header,
.checkout-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.home-top {
  margin-bottom: 26rpx;
}

.home-actions {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 6rpx;
}

.eyebrow {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #40332e;
  font-size: 38rpx;
  line-height: 1.4;
  font-weight: 800;
  letter-spacing: -1rpx;
}

.eyebrow text:first-child {
  font-size: 32rpx;
}

.date-label {
  display: block;
  margin-top: 4rpx;
  color: #735f56;
  font-size: 23rpx;
  font-weight: 600;
  text-shadow: 0 1rpx 4rpx rgba(255, 252, 247, 0.76);
}

.avatar {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  padding: 5rpx;
  border-radius: 50%;
  box-sizing: border-box;
  background: linear-gradient(145deg, #ffd6c4, #f4a284);
  box-shadow: 0 8rpx 20rpx rgba(219, 112, 78, 0.2);
}

.avatar-face {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #fff;
  border-radius: 50%;
  box-sizing: border-box;
  background: #fff0e8;
  color: #e88667;
  font-size: 38rpx;
  font-weight: 700;
}

.avatar-heart {
  position: absolute;
  right: -2rpx;
  bottom: -2rpx;
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid #fff;
  border-radius: 50%;
  background: #ee6652;
  color: #fff;
  font-size: 16rpx;
  line-height: 28rpx;
  text-align: center;
}

.hero-swiper {
  width: 100%;
  height: 350rpx;
  box-sizing: border-box;
  background: transparent;
}
.hero-swiper-item {
  box-sizing: border-box;
  display: flex;
  align-items: flex-start;
  padding: 0;
  background: transparent;
}

.hero-card {
  position: relative;
  width: 100%;
  height: 350rpx;
  overflow: hidden;
  padding: 38rpx 30rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.68);
  border-radius: 38rpx;
  box-sizing: border-box;
  background:
    radial-gradient(
      circle at 18% 0,
      rgba(255, 255, 255, 0.18),
      transparent 42%
    ),
    linear-gradient(135deg, #f5895f 0%, #ec5a47 56%, #d6443a 100%);
  box-shadow: 0 16rpx 38rpx rgba(116, 58, 40, 0.2);
  color: #fff;
}
/* 新品卡：浅色 tone 背景（同 mini 卡）+ 深棕字，文字加白色描边保证任何浅 tone 下清晰 */
.hero-card--new {
  color: #4a3326;
  border-color: rgba(128, 84, 58, 0.24);
  box-shadow: 0 16rpx 38rpx rgba(100, 66, 45, 0.16);
}
.hero-card--new .hero-copy {
  text-shadow:
    0 0 4rpx rgba(255, 255, 255, 0.85),
    0 1rpx 2rpx rgba(255, 255, 255, 0.9);
}
.hero-card--new .hero-glow {
  background: rgba(255, 255, 255, 0.4);
}
.hero-card--new .hero-subtitle {
  opacity: 0.78;
}
.hero-card--new .hero-button {
  background: #4a3326;
  color: #fff;
}
.hero-card--new .hero-plate.has-image .hero-plate-image {
  filter: drop-shadow(0 16rpx 26rpx rgba(80, 55, 35, 0.28));
}

.hero-glow {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.11);
}

.hero-glow-one {
  width: 310rpx;
  height: 310rpx;
  right: -80rpx;
  top: -100rpx;
}
.hero-glow-two {
  width: 160rpx;
  height: 160rpx;
  left: 290rpx;
  bottom: -110rpx;
}
.hero-copy {
  position: relative;
  z-index: 2;
  width: 56%;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.hero-kicker {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 10rpx;
  font-size: 22rpx;
  font-weight: 600;
  opacity: 0.9;
}

.hero-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #ffe49a;
}
.hero-dot--new {
  background: #4a3326;
}
.hero-title {
  display: block;
  font-size: 48rpx;
  line-height: 1.12;
  font-weight: 800;
  letter-spacing: 2rpx;
}
.hero-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 20rpx;
  opacity: 0.78;
  white-space: nowrap;
}

.hero-button {
  align-self: flex-start;
  width: auto;
  min-width: 150rpx;
  max-width: 100%;
  height: 62rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin: 22rpx 0 0;
  padding: 0 34rpx;
  box-sizing: border-box;
  border-radius: 31rpx;
  background: #fff;
  color: #e45b45;
  font-size: 23rpx;
  line-height: 1;
  font-weight: 700;
  box-shadow: 0 8rpx 20rpx rgba(140, 40, 28, 0.16);
  transition: transform 0.24s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.hero-button text {
  margin-left: 8rpx;
  line-height: 1;
}
.button-pressed {
  transform: scale(0.94);
  opacity: 0.9;
}

.hero-art {
  position: absolute;
  z-index: 1;
  right: -6rpx;
  bottom: 5rpx;
  width: 300rpx;
  height: 300rpx;
}

.hero-plate {
  position: absolute;
  right: 10rpx;
  bottom: 28rpx;
  width: 264rpx;
  height: 210rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 10rpx solid rgba(255, 244, 229, 0.92);
  border-radius: 50%;
  box-sizing: border-box;
  background: #ffc065;
  box-shadow: 0 18rpx 35rpx rgba(122, 34, 25, 0.23);
  font-size: 130rpx;
  transform: rotate(-7deg);
  overflow: hidden;
}
.hero-plate-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  transform: rotate(7deg) scale(1.12);
}
.hero-plate.has-image {
  width: 330rpx;
  height: 330rpx;
  right: -6rpx;
  bottom: 0;
  border: none;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
  transform: none;
  overflow: visible;
}
.hero-plate.has-image .hero-plate-image {
  border-radius: 0;
  transform: none;
  filter: drop-shadow(0 16rpx 26rpx rgba(122, 34, 25, 0.32));
}

/* 菜品上方的动态雾气 */
.hero-mist {
  position: absolute;
  z-index: 2;
  right: 86rpx;
  top: 38rpx;
  width: 150rpx;
  height: 150rpx;
  pointer-events: none;
}
.mist {
  position: absolute;
  bottom: 0;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.6);
  filter: blur(4rpx);
  opacity: 0;
  will-change: transform, opacity;
  animation: mist-rise 5s ease-in-out infinite;
}
.mist-one {
  left: 30rpx;
  animation-delay: 0s;
}
.mist-two {
  left: 66rpx;
  animation-delay: 1.1s;
}
.mist-three {
  left: 100rpx;
  animation-delay: 2.2s;
}
@keyframes mist-rise {
  0% {
    transform: translateY(0) scale(0.7);
    opacity: 0;
  }
  20% {
    opacity: 0.75;
  }
  60% {
    opacity: 0.5;
  }
  100% {
    transform: translateY(-110rpx) scale(2.4);
    opacity: 0;
  }
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
  margin: 30rpx 0 42rpx;
}

.quick-item {
  position: relative;
  height: 142rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border: 2rpx solid rgba(132, 88, 64, 0.2);
  border-radius: 28rpx;
  background: linear-gradient(160deg, #ffffff, #fff6ef);
  box-shadow:
    0 12rpx 30rpx rgba(84, 51, 38, 0.13),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  font-size: 21rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
  transition:
    transform 0.22s cubic-bezier(0.34, 1.56, 0.64, 1),
    box-shadow 0.22s ease;
}

.quick-item--pressed {
  transform: translateY(3rpx) scale(0.96);
  box-shadow: 0 4rpx 14rpx rgba(84, 51, 38, 0.08);
}
.quick-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 22rpx;
  font-size: 32rpx;
  line-height: 64rpx;
  text-align: center;
  font-weight: 800;
  box-shadow: inset 0 -3rpx 8rpx rgba(120, 70, 50, 0.06);
}
.quick-orange {
  color: #e76447;
  background: linear-gradient(150deg, #fff2e9, #ffe2d2);
}
.quick-purple {
  color: #8e74c7;
  background: linear-gradient(150deg, #f3effc, #e9e1fb);
}
.quick-green {
  color: #5b9f83;
  background: linear-gradient(150deg, #ecf8f2, #ddf2e8);
}
.quick-pink {
  color: #dc7184;
  background: linear-gradient(150deg, #fff1f3, #ffe0e6);
}
.quick-badge {
  position: absolute;
  top: 12rpx;
  right: 15rpx;
  min-width: 28rpx;
  height: 28rpx;
