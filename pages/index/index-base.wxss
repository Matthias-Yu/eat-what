  box-shadow:
    0 12rpx 28rpx rgba(77, 46, 34, 0.06),
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.82);
  transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
}

.menu-page.stagger > .food-grid.food-grid--motion-a {
  opacity: 1;
  animation: food-grid-enter-a 280ms cubic-bezier(0.2, 0.82, 0.28, 1) both;
}

.menu-page.stagger > .food-grid.food-grid--motion-b {
  opacity: 1;
  animation: food-grid-enter-b 280ms cubic-bezier(0.2, 0.82, 0.28, 1) both;
}

@keyframes food-grid-enter-a {
  from { opacity: 0.72; transform: translateY(8rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes food-grid-enter-b {
  from { opacity: 0.72; transform: translateY(8rpx); }
  to { opacity: 1; transform: translateY(0); }
}

