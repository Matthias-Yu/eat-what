  justify-content: center;
  border-radius: 18rpx;
  font-size: 34rpx;
  line-height: 62rpx;
  text-align: center;
}
.managed-food-image {
  width: 88%;
  height: 88%;
  filter: drop-shadow(0 6rpx 6rpx rgba(106, 64, 37, 0.1));
}
.managed-menu-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  margin: 0 14rpx;
}
.managed-menu-copy text:first-child {
  overflow: hidden;
  color: #493832;
  font-size: 22rpx;
  font-weight: 700;
  white-space: nowrap;
  text-overflow: ellipsis;
}
.managed-menu-copy text:last-child {
  margin-top: 5rpx;
  color: #a89790;
  font-size: 17rpx;
}
.managed-menu-mark {
  padding: 5rpx 12rpx;
  border-radius: 13rpx;
  background: #fff0e9;
  color: #e35f48;
  font-size: 16rpx;
  font-weight: 700;
}
.menu-form-row {
  display: grid;
  grid-template-columns: 150rpx 1fr;
  gap: 16rpx;
}
.menu-emoji-field,
.menu-tags-field {
  min-width: 0;
}
.option-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.option-chip {
  min-width: 104rpx;
  height: 58rpx;
  padding: 0 19rpx;
  border: 1rpx solid #ebded7;
  border-radius: 21rpx;
  box-sizing: border-box;
  background: #fff;
  color: #917f77;
  font-size: 20rpx;
  line-height: 58rpx;
  text-align: center;
}
.option-chip.is-active {
  border-color: #ef795e;
  background: #fff0e9;
  color: #e35f48;
  font-weight: 700;
}
.save-todo-button,
.save-menu-button {
  height: 82rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 30rpx 0 0;
  padding: 0;
  border-radius: 27rpx;
  background: linear-gradient(135deg, #f17a5c, #e95c47);
  color: #fff;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 700;
}

.success-overlay {
  z-index: 120;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}
.success-card {
  position: relative;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  overflow: hidden;
  padding: 60rpx 38rpx 40rpx;
  border-radius: 38rpx;
  box-sizing: border-box;
  background: #fffaf7;
  box-shadow: 0 25rpx 70rpx rgba(50, 32, 25, 0.25);
  animation: pop-in 0.35s ease both;
}
@keyframes pop-in {
  from {
    opacity: 0;
    transform: scale(0.83);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}
.success-icon {
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: linear-gradient(145deg, #f69372, #e85d48);
  color: #fff;
  font-size: 58rpx;
  box-shadow: 0 15rpx 32rpx rgba(216, 83, 59, 0.22);
}
.success-title {
  margin-top: 28rpx;
  color: #3f312c;
  font-size: 34rpx;
  font-weight: 800;
}
.success-copy {
  margin-top: 13rpx;
  color: #98867e;
  font-size: 21rpx;
  line-height: 1.7;
  text-align: center;
}
.success-card button {
  width: 100%;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 35rpx;
  padding: 0;
  border-radius: 27rpx;
  background: #ef684f;
  color: #fff;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 700;
}
.success-confetti {
  position: absolute;
}
.confetti-one {
  left: 75rpx;
  top: 80rpx;
  color: #e7b94d;
  font-size: 30rpx;
}
.confetti-two {
  right: 90rpx;
  top: 65rpx;
  color: #70ad8c;
  font-size: 22rpx;
}
.confetti-three {
  right: 50rpx;
  top: 180rpx;
  color: #ec7f8d;
  font-size: 26rpx;
  transform: rotate(14deg);
}

