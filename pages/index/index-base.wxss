/* Floating cart */
.cart-float {
  position: fixed;
  z-index: 45;
  left: 42rpx;
  right: 42rpx;
  bottom: calc(142rpx + env(safe-area-inset-bottom));
  height: 92rpx;
  display: flex;
  align-items: center;
  padding: 0 13rpx;
  border-radius: 30rpx;
  background: #3e332f;
  color: #fff;
  box-shadow: 0 15rpx 40rpx rgba(52, 38, 32, 0.27);
  transition: transform 0.15s ease;
}
.cart-float--pressed {
  transform: scale(0.98);
}
.cart-float-icon {
  position: relative;
  width: 67rpx;
  height: 67rpx;
  border-radius: 22rpx;
  background: #ef684f;
  font-size: 34rpx;
  line-height: 67rpx;
  text-align: center;
}
.cart-float-icon text {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 26rpx;
  height: 26rpx;
  padding: 0 4rpx;
  border: 3rpx solid #3e332f;
  border-radius: 15rpx;
  box-sizing: border-box;
  background: #fff;
  color: #e35f49;
  font-size: 15rpx;
  line-height: 23rpx;
}
.cart-float-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  margin-left: 15rpx;
}
.cart-float-copy text:first-child {
  font-size: 22rpx;
  font-weight: 700;
}
.cart-float-copy text:last-child {
  color: #bdb3ae;
  font-size: 16rpx;
}
.cart-float-total {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-right: 13rpx;
