  box-shadow: 0 5rpx 12rpx rgba(197, 75, 55, 0.22);
}
@keyframes card-fly {
  from {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1) rotate(0deg);
  }
  to {
    opacity: 0;
    transform: translate3d(var(--fly-end-x), var(--fly-end-y), 0) scale(0.08)
      rotate(var(--fly-end-rotate));
  }
}

