/* 随机选菜弹层 */
.random-overlay {
  z-index: 120;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}
.random-card {
  position: relative;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 50rpx 38rpx 38rpx;
  border-radius: 40rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #fffaf6, #fff3ea);
  box-shadow: 0 25rpx 70rpx rgba(50, 32, 25, 0.25);
  animation: pop-in 0.32s cubic-bezier(0.34, 1.56, 0.64, 1) both;
}
.random-card-close {
  position: absolute;
  right: 24rpx;
  top: 24rpx;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #f1e8e3;
  color: #8e7f78;
  font-size: 36rpx;
  line-height: 49rpx;
  text-align: center;
}
.random-kicker {
  color: #c08a73;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}
.random-dish {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 18rpx;
  transition: transform 0.18s ease;
}
.random-dish.is-rolling {
  animation: dish-shake 0.3s ease-in-out infinite;
}
@keyframes dish-shake {
  0%,
  100% {
    transform: translateY(0) rotate(0);
  }
  25% {
    transform: translateY(-6rpx) rotate(-3deg);
  }
  75% {
    transform: translateY(6rpx) rotate(3deg);
  }
}
.random-dish-art {
  width: 220rpx;
  height: 220rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 36rpx;
  font-size: 120rpx;
}
.random-dish-image {
  width: 100%;
  height: 100%;
  filter: drop-shadow(0 12rpx 18rpx rgba(122, 34, 25, 0.2));
}
.random-dish-name {
  margin-top: 22rpx;
  color: #3f312c;
  font-size: 38rpx;
  font-weight: 800;
  letter-spacing: -0.5rpx;
}
.random-dish-desc {
  margin-top: 8rpx;
  color: #98867e;
  font-size: 22rpx;
}
.random-actions {
  display: flex;
  width: 100%;
  gap: 18rpx;
  margin-top: 38rpx;
}
.random-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 27rpx;
  font-size: 24rpx;
  font-weight: 700;
}
.random-btn.ghost {
  background: #f3e7e0;
  color: #8a6f63;
}
.random-btn.solid {
  background: linear-gradient(135deg, #f17a5c, #e95c47);
  color: #fff;
  box-shadow: 0 11rpx 26rpx rgba(216, 83, 58, 0.2);
}

/* 纪念日小卡片 */
.anniversary-card {
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
  padding: 30rpx 34rpx;
  border: 2rpx solid rgba(202, 105, 76, 0.3);
  border-radius: 32rpx;
  background: linear-gradient(135deg, #fff3ec, #ffe1d4);
  box-shadow:
    0 16rpx 36rpx rgba(180, 76, 52, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  transition: transform 0.22s ease;
}
.anniversary-card:active {
  transform: translateY(2rpx);
}
.anniversary-glow {
  position: absolute;
  right: -40rpx;
  top: -50rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: radial-gradient(
    circle,
    rgba(255, 173, 142, 0.55),
    rgba(255, 173, 142, 0)
  );
}
.anniversary-copy {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
}
.anniversary-title {
  color: #b46a52;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}
.anniversary-count {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  margin-top: 6rpx;
  color: #e95c47;
  transform-origin: center;
  transform-style: preserve-3d;
}
.anniversary-count.is-flipping.flip-frame-0 .anniversary-days {
  animation: anniversary-page-flip 0.18s ease-in-out;
}
.anniversary-count.is-flipping.flip-frame-1 .anniversary-days {
  animation: anniversary-page-flip-alt 0.18s ease-in-out;
}
.anniversary-prefix,
.anniversary-suffix {
  font-size: 26rpx;
  font-weight: 700;
}
.anniversary-days {
  display: inline-block;
  font-size: 64rpx;
  font-weight: 800;
  letter-spacing: -1rpx;
  line-height: 1;
  transform-origin: center;
}
.anniversary-since {
  margin-top: 8rpx;
  color: #b79086;
  font-size: 19rpx;
}
.anniversary-heart {
  position: relative;
  z-index: 1;
  color: #ef654d;
  font-size: 64rpx;
  opacity: 0.85;
}

@keyframes anniversary-page-flip {
  0% {
    opacity: 0.58;
    transform: perspective(460rpx) rotateX(72deg) translateY(-8rpx);
  }
  52% {
    opacity: 1;
    transform: perspective(460rpx) rotateX(-12deg) translateY(2rpx);
  }
  100% {
    opacity: 1;
    transform: perspective(460rpx) rotateX(0deg) translateY(0);
  }
}
@keyframes anniversary-page-flip-alt {
  0% {
    opacity: 0.58;
    transform: perspective(460rpx) rotateX(72deg) translateY(-8rpx);
  }
  52% {
    opacity: 1;
    transform: perspective(460rpx) rotateX(-12deg) translateY(2rpx);
  }
  100% {
    opacity: 1;
    transform: perspective(460rpx) rotateX(0deg) translateY(0);
  }
}
.anniversary-empty {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
}
.anniversary-empty-text {
  color: #c2705a;
  font-size: 24rpx;
  font-weight: 700;
}
.anniversary-empty-arrow {
  color: #e4674f;
  font-size: 34rpx;
  font-weight: 700;
}

/* 纪念日设置弹层 */
.anniversary-card-sheet {
  background: linear-gradient(180deg, #fffaf6, #fff3ea);
}
.anniversary-form {
  width: 100%;
