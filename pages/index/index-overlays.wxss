/* 家庭来信：首页信封 */
.home-letter-arrival {
  position: relative;
  width: 100%;
  min-height: 214rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 28rpx;
  overflow: hidden;
  margin: 0 0 24rpx;
  padding: 26rpx 28rpx;
  border: 2rpx solid rgba(181, 105, 73, 0.32);
  border-radius: 36rpx;
  box-sizing: border-box;
  background: linear-gradient(140deg, rgba(255, 252, 245, 0.94), rgba(255, 236, 222, 0.9));
  box-shadow: 0 18rpx 42rpx rgba(124, 79, 59, 0.19);
  transition: transform 0.24s cubic-bezier(0.2, 0.9, 0.25, 1), opacity 0.2s ease;
}
.home-letter-arrival--pressed {
  transform: scale(0.975);
  opacity: 0.94;
}
.letter-glow-ring {
  position: absolute;
  left: -26rpx;
  top: -58rpx;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(244, 176, 139, 0.24), rgba(244, 176, 139, 0) 68%);
  animation: letter-glow-breathe 2.8s ease-in-out infinite alternate;
}
.letter-sparkle {
  position: absolute;
  z-index: 6;
  color: #d79b71;
  font-size: 20rpx;
  animation: letter-sparkle 2.2s ease-in-out infinite;
}
.sparkle-left { left: 28rpx; top: 35rpx; }
.sparkle-right { left: 248rpx; bottom: 34rpx; animation-delay: 0.8s; }
.home-envelope {
  position: relative;
  z-index: 3;
  flex: 0 0 auto;
  width: 208rpx;
  height: 132rpx;
  filter: drop-shadow(0 14rpx 13rpx rgba(101, 61, 43, 0.2));
  animation: home-envelope-float 2.8s ease-in-out infinite;
}
.home-envelope-image {
  width: 100%;
  height: 100%;
}
.home-letter-copy {
  position: relative;
  z-index: 4;
  min-width: 0;
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: flex-start;
}
.home-letter-kicker {
  color: #b2775d;
  font-size: 16rpx;
  font-weight: 700;
  letter-spacing: 2.4rpx;
}
.home-letter-title {
  margin-top: 8rpx;
  color: #50362d;
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}
.home-letter-meta {
  max-width: 100%;
  margin-top: 9rpx;
  overflow: hidden;
  color: #9a7667;
  font-size: 19rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.home-letter-arrival.is-unread::after {
  content: "NEW";
  position: absolute;
  right: -34rpx;
  top: 20rpx;
  width: 120rpx;
  padding: 5rpx 0;
  transform: rotate(40deg);
  background: #b9604f;
  color: #fff5ed;
  font-size: 13rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  text-align: center;
}
@keyframes home-envelope-float {
  0%, 100% { transform: translateY(0) rotate(-1deg); }
  50% { transform: translateY(-8rpx) rotate(1deg); }
}
@keyframes letter-glow-breathe {
  from { transform: scale(0.92); opacity: 0.7; }
  to { transform: scale(1.08); opacity: 1; }
}
@keyframes letter-sparkle {
  0%, 100% { transform: scale(0.7) rotate(0); opacity: 0.35; }
  50% { transform: scale(1.15) rotate(24deg); opacity: 1; }
}

/* 家庭云空间：按邀请、常用功能、管理员设置分组。 */
