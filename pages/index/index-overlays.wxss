/* 写信弹层 */
.letter-compose-overlay,
.letter-viewer-overlay {
  position: fixed;
  z-index: 150;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 38rpx 30rpx calc(38rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: rgba(43, 29, 24, 0.7);
  backdrop-filter: blur(12rpx);
  animation: fade-in 0.3s ease both;
}
.letter-compose-card {
  position: relative;
  width: 100%;
  max-height: 86vh;
  overflow: hidden;
  border-radius: 12rpx 38rpx 14rpx 34rpx;
  background: #fff8e8;
  box-shadow: 0 36rpx 90rpx rgba(34, 20, 14, 0.36);
  transform: rotate(-0.35deg);
  animation: letter-compose-in 0.55s cubic-bezier(0.16, 1, 0.3, 1) both;
}
.letter-paper-texture {
  position: absolute;
  z-index: 0;
  inset: 0;
  width: 100%;
  height: 100%;
  opacity: 0.92;
  pointer-events: none;
}
.letter-compose-content {
  position: relative;
  z-index: 1;
  padding: 40rpx 38rpx 34rpx;
}
.letter-compose-top { display: flex; align-items: center; justify-content: space-between; }
.letter-compose-top > text {
  color: #5a3c30;
  font-size: 38rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
}
.letter-compose-close,
.letter-viewer-close {
  width: 58rpx;
  height: 58rpx;
  border: 1rpx solid rgba(120, 77, 58, 0.15);
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.55);
  color: #866858;
  font-family: sans-serif;
  font-size: 38rpx;
  font-weight: 300;
  line-height: 54rpx;
  text-align: center;
}
.letter-compose-hint { display: block; margin-top: 9rpx; color: #a08474; font-size: 19rpx; }
.letter-textarea {
  width: 100%;
  height: 470rpx;
  margin-top: 26rpx;
  padding: 20rpx 16rpx;
  border: 0;
  border-radius: 10rpx;
  box-sizing: border-box;
  background: repeating-linear-gradient(to bottom, transparent 0, transparent 57rpx, rgba(145, 104, 81, 0.13) 58rpx, transparent 59rpx);
  color: #49372f;
  font-family: "FamilyHandwriting", -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif;
  font-size: 30rpx;
  font-weight: 400;
  line-height: 59rpx;
  letter-spacing: 2rpx;
}
.letter-placeholder { color: rgba(119, 88, 73, 0.42); }
.letter-send-button {
  width: 100%;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 26rpx 0 0;
  padding: 0;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #c9785b, #a95143);
  color: #fff8ee;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 700;
  letter-spacing: 2rpx;
  box-shadow: 0 13rpx 26rpx rgba(139, 65, 49, 0.2);
}
@keyframes letter-compose-in {
  from { opacity: 0; transform: translateY(50rpx) rotate(-2deg) scale(0.94); }
  to { opacity: 1; transform: translateY(0) rotate(-0.35deg) scale(1); }
}

/* 拆信舞台 */
.letter-viewer-overlay { overflow: hidden; background: rgba(38, 25, 20, 0.78); }
.letter-viewer-overlay::before {
  content: "";
  position: absolute;
  width: 900rpx;
  height: 900rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(232, 174, 133, 0.22), rgba(232, 174, 133, 0) 67%);
  animation: letter-stage-glow 2.4s ease-in-out infinite alternate;
}
.letter-scene {
  position: relative;
  width: 100%;
  height: 86vh;
  max-height: 1120rpx;
  perspective: 1400rpx;
}
.letter-viewer-close {
  position: absolute;
  z-index: 30;
  right: 4rpx;
  top: 0;
  border-color: rgba(255,255,255,0.16);
  background: rgba(255,255,255,0.12);
  color: #fff5ed;
}
.letter-withdraw-button {
  position: absolute;
  z-index: 30;
  left: 4rpx;
  top: 0;
  width: 184rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  border: 1rpx solid rgba(255, 238, 228, 0.24);
  border-radius: 29rpx;
  background: rgba(72, 45, 36, 0.58);
  color: rgba(255, 246, 239, 0.92);
  font-size: 20rpx;
  line-height: 1;
  font-weight: 600;
  backdrop-filter: blur(10rpx);
}
.letter-withdraw-button::after { border: 0; }
.letter-paper-card {
  position: absolute;
  z-index: 20;
  left: 50%;
  top: 50%;
  width: 650rpx;
  height: 930rpx;
  overflow: hidden;
  margin: -465rpx 0 0 -325rpx;
  border-radius: 10rpx 28rpx 8rpx 24rpx;
  background: #fff8e8;
  box-shadow: 0 40rpx 100rpx rgba(20, 10, 6, 0.4);
  opacity: 1;
  transform: translateY(0) scale(1) rotate(-0.35deg);
  animation: letter-direct-in 0.34s cubic-bezier(0.16, 1, 0.3, 1) both;
}
.letter-paper-scroll { position: relative; z-index: 2; width: 100%; height: 100%; }
.letter-paper-content {
  min-height: 100%;
  padding: 78rpx 54rpx 72rpx;
  box-sizing: border-box;
  background: repeating-linear-gradient(to bottom, transparent 0, transparent 65rpx, rgba(133, 97, 75, 0.095) 66rpx, transparent 67rpx);
  opacity: 1;
}
.letter-paper-body {
  display: block;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  color: #43342d;
  font-family: "FamilyHandwriting", -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif;
  font-size: 31rpx;
  font-weight: 400;
  line-height: 2.08;
  letter-spacing: 2.5rpx;
  white-space: pre-wrap;
  word-break: break-all;
  overflow-wrap: break-word;
}
@keyframes letter-direct-in {
  from { opacity: 0; transform: translateY(30rpx) scale(0.96) rotate(-0.7deg); }
  to { opacity: 1; transform: translateY(0) scale(1) rotate(-0.35deg); }
}
@keyframes letter-stage-glow {
  from { transform: scale(0.9); opacity: 0.55; }
  to { transform: scale(1.1); opacity: 1; }
}

@media (max-height: 700px) {
  .letter-textarea { height: 330rpx; }
  .letter-paper-card { height: 780rpx; margin-top: -390rpx; }
}

