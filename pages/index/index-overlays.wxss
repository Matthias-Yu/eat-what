  font-size: 19rpx;
  font-weight: 600;
}
.messages-sheet-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 80rpx 0;
  color: #9c8b83;
  font-size: 23rpx;
}
.messages-sheet-empty text:first-child {
  color: #ee876f;
