}
.save-anniversary-button {
  width: 100%;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 30rpx 0 0;
  padding: 0;
  border-radius: 27rpx;
  background: linear-gradient(135deg, #f17a5c, #e95c47);
  color: #fff;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 700;
  box-shadow: 0 11rpx 26rpx rgba(216, 83, 58, 0.18);
}
.anniversary-clear {
  display: block;
  margin-top: 22rpx;
  color: #c98a73;
  font-size: 21rpx;
  font-weight: 600;
  text-align: center;
}

/* 悄悄话首页模块 */
.messages-heading {
  margin-top: 42rpx;
}
.messages-card {
  overflow: hidden;
  padding: 8rpx 24rpx 24rpx;
  border: 2rpx solid rgba(132, 88, 64, 0.2);
  border-radius: 30rpx;
  background: linear-gradient(170deg, #ffffff, #fffaf6);
  box-shadow:
    0 14rpx 32rpx rgba(80, 50, 36, 0.13),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}
.message-mini {
  padding: 22rpx 2rpx;
  border-bottom: 1rpx solid #f6eee9;
}
.message-mini:last-of-type {
  border-bottom: 0;
}
.message-mini-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}
.message-author {
  color: #d2674f;
  font-size: 20rpx;
  font-weight: 700;
}
.message-author-me {
  color: #7c6b63;
  font-weight: 600;
}
.message-time {
  color: #7c6b63;
  font-size: 18rpx;
  font-weight: 600;
}
.message-text {
  display: block;
  color: #4a3b35;
  font-size: 24rpx;
  line-height: 1.5;
  word-break: break-all;
}
.message-reactions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}
.reaction-chip {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  height: 44rpx;
  padding: 0 16rpx;
  border: 1rpx solid #ecdfd8;
  border-radius: 22rpx;
  background: #fbf5f1;
  transition:
    transform 0.18s ease,
    background 0.18s ease;
}
.reaction-chip:active {
  transform: scale(0.9);
}
.reaction-chip.is-mine {
  border-color: #f3b3a4;
  background: #ffe9e2;
}
.reaction-emoji {
  font-size: 26rpx;
  line-height: 1;
}
.reaction-count {
  color: #7b6258;
  font-size: 20rpx;
  font-weight: 600;
}
.reaction-chip.is-mine .reaction-count {
  color: #e2613f;
}
.messages-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 36rpx 0 30rpx;
  color: #75645c;
  font-size: 22rpx;
  font-weight: 600;
}
.messages-empty-icon {
  color: #ee876f;
  font-size: 40rpx;
}
.write-message-button {
  width: 100%;
  height: 78rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin: 18rpx 0 0;
  padding: 0;
  border-radius: 24rpx;
  background: #fff0ea;
  color: #e4674f;
  font-size: 23rpx;
  line-height: 1;
  font-weight: 700;
}

/* 悄悄话留言弹层 */
.messages-list {
  max-height: 620rpx;
}
.all-orders-list {
  max-height: 720rpx;
}
.all-orders-list .order-card {
  margin-bottom: 13rpx;
}
.all-orders-list .order-card:last-child {
