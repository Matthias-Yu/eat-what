<navigation-bar title="" back="{{false}}" color="#382d29" background="transparent"></navigation-bar>

<scroll-view class="page-scroll" scroll-y enhanced show-scrollbar="{{false}}" scroll-top="{{scrollTop}}" scroll-with-animation="{{false}}">
  <!-- 首页 -->
  <view wx:if="{{activeTab === 'home'}}" class="page home-page stagger">
    <view class="home-top">
      <view>
        <view class="eyebrow"><text>{{greeting.icon}}</text><text>{{greeting.text}}，宝贝</text></view>
        <text class="date-label">{{dateLabel}}</text>
      </view>
      <view class="home-actions">
        <view class="farm-entry-orb" data-target="farm" bindtap="navigateFromCard" hover-class="farm-entry-orb--pressed">
          <view class="farm-entry-face">
            <image class="farm-entry-image" src="{{farmImages.entry}}" mode="aspectFill"></image>
          </view>
          <text wx:if="{{farmStats.ready}}" class="farm-entry-badge">{{farmStats.ready > 99 ? '99+' : farmStats.ready}}</text>
        </view>
        <view class="avatar" bindtap="navigateFromCard" data-target="profile" hover-class="tap-scale--active">
          <view class="avatar-face">☺</view>
          <view class="avatar-heart">♥</view>
        </view>
      </view>
    </view>

    <view class="anniversary-card" bindtap="openAnniversarySheet" hover-class="tap-scale--active">
      <view class="anniversary-glow"></view>
      <block wx:if="{{anniversary}}">
        <view class="anniversary-copy">
          <text class="anniversary-title">{{anniversary.title}}</text>
          <view class="anniversary-count {{anniversaryFlipActive ? 'is-flipping' : ''}} flip-frame-{{anniversaryFlipFrame}}"><text class="anniversary-prefix">第</text><text class="anniversary-days">{{anniversaryDisplayDays}}</text><text class="anniversary-suffix">天</text></view>
          <text class="anniversary-since">从 {{anniversary.date}} 开始</text>
        </view>
        <view class="anniversary-heart">♥</view>
      </block>
      <view wx:else class="anniversary-empty">
        <text class="anniversary-empty-text">记录属于你们的日子</text>
        <text class="anniversary-empty-arrow">›</text>
      </view>
    </view>

    <swiper
      wx:if="{{bannerItems.length}}"
      class="hero-swiper"
      autoplay
      interval="5000"
      duration="600"
      circular="{{bannerItems.length > 1}}"
      indicator-dots="{{bannerItems.length > 1}}"
      indicator-color="rgba(255,255,255,0.5)"
      indicator-active-color="#ffffff"
    >
      <swiper-item wx:for="{{bannerItems}}" wx:key="id" class="hero-swiper-item">
        <view class="hero-card {{item.bannerTag === '新品' ? 'hero-card--new tone-' + (item.tone || 'sunset') : ''}}">
          <view class="hero-glow hero-glow-one"></view>
          <view class="hero-glow hero-glow-two"></view>
          <view class="hero-copy">
            <view class="hero-kicker"><text class="hero-dot {{item.bannerTag === '新品' ? 'hero-dot--new' : ''}}"></text> {{item.bannerTag === '新品' ? '新品上新' : '今晚推荐'}}</view>
            <text class="hero-title">{{item.name}}</text>
            <text class="hero-subtitle">{{item.description}}</text>
            <button class="hero-button" data-category="recommend" bindtap="exploreMenu" hover-class="button-pressed">去看看 <text>→</text></button>
          </view>
          <view class="hero-art">
            <view wx:if="{{item.image}}" class="hero-mist">
              <view class="mist mist-one"></view>
              <view class="mist mist-two"></view>
              <view class="mist mist-three"></view>
            </view>
            <view class="hero-plate {{item.image ? 'has-image' : ''}}">
              <image wx:if="{{item.image}}" class="hero-plate-image" src="{{item.image}}" mode="aspectFit"></image>
              <text wx:else>{{item.emoji || '🍲'}}</text>
            </view>
          </view>
        </view>
      </swiper-item>
    </swiper>

    <view class="quick-grid">
      <view class="quick-item" data-target="menu" bindtap="navigateFromCard" hover-class="quick-item--pressed">
        <view class="quick-icon quick-orange">♨</view>
        <text>开始点餐</text>
      </view>
      <view class="quick-item" data-target="todo" bindtap="navigateFromCard" hover-class="quick-item--pressed">
        <view class="quick-icon quick-purple">✓</view>
        <text>今日待办</text>
        <text wx:if="{{todoStats.pending}}" class="quick-badge">{{todoStats.pending}}</text>
      </view>
      <view class="quick-item" data-target="wishlist" bindtap="navigateFromCard" hover-class="quick-item--pressed">
        <view class="quick-icon quick-green">☆</view>
        <text>心愿单</text>
        <text wx:if="{{wishStats.pending}}" class="quick-badge">{{wishStats.pending}}</text>
      </view>
      <view class="quick-item" data-target="profile" bindtap="navigateFromCard" hover-class="quick-item--pressed">
        <view class="quick-icon quick-pink">♡</view>
        <text>我们的小家</text>
      </view>
    </view>

    <view class="section-heading">
      <view><text class="section-title">今日好味</text><text class="section-subtitle">按喜欢的来，今天也要好好吃饭</text></view>
      <text class="section-more" data-category="recommend" bindtap="exploreMenu">全部 →</text>
    </view>
    <scroll-view class="recommend-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="recommend-row">
        <view wx:for="{{recommendedItems}}" wx:key="id" id="dish-card-{{item.id}}" class="mini-food-card">
          <view class="mini-food-art tone-{{item.tone}}">
            <image wx:if="{{item.image}}" class="mini-food-image" src="{{item.image}}" mode="aspectFit" lazy-load="{{true}}"></image>
            <text wx:else>{{item.emoji}}</text>
            <view class="food-tag">{{item.tags[0]}}</view>
          </view>
          <text class="mini-food-name">{{item.name}}</text>
          <view class="mini-food-bottom">
            <text class="mini-food-hint">{{item.highlight}}</text>
            <view class="add-mini" data-id="{{item.id}}" catchtap="addToCart" hover-class="add-pressed">＋</view>
          </view>
        </view>
      </view>
    </scroll-view>

    <view class="section-heading todo-heading">
      <view><text class="section-title">今日小事</text><text class="section-subtitle">一件件完成，生活就有了形状</text></view>
      <text class="section-more" data-target="todo" bindtap="navigateFromCard">管理 →</text>
    </view>
    <view class="home-todo-card">
      <block wx:if="{{homeTodos.length}}">
        <view wx:for="{{homeTodos}}" wx:key="id" class="home-todo-row">
          <view class="todo-check-small" data-id="{{item.id}}" bindtap="toggleTodo"></view>
          <view class="home-todo-copy">
            <text class="home-todo-title">{{item.title}}</text>
            <text class="home-todo-meta">{{item.category}} · {{item.due}}</text>
          </view>
          <text class="todo-arrow">›</text>
        </view>
      </block>
      <view wx:else class="home-empty">
        <text class="home-empty-icon">✦</text>
        <text>今天的事情都完成啦</text>
      </view>
    </view>
    <view class="section-heading messages-heading">
      <view><text class="section-title">悄悄话</text><text class="section-subtitle">把想说的话，轻轻留在这里</text></view>
      <text class="section-more" bindtap="openMessages">全部 →</text>
    </view>
    <view class="messages-card">
      <block wx:if="{{recentMessages.length}}">
        <view wx:for="{{recentMessages}}" wx:key="id" class="message-mini">
          <view class="message-mini-top"><text class="message-author">{{item.authorName}}</text><text class="message-time">{{item.timeText}}</text></view>
          <text class="message-text">{{item.text}}</text>
        </view>
      </block>
      <view wx:else class="messages-empty">
        <text class="messages-empty-icon">✎</text>
        <text>还没有悄悄话，写下第一句吧</text>
      </view>
      <button class="write-message-button" bindtap="openMessages" hover-class="button-pressed"><text>＋</text> 写一句</button>
    </view>
    <view class="love-note">♡ 好好吃饭，好好生活，也好好爱你</view>
  </view>

  <!-- 点餐 -->
  <view wx:elif="{{activeTab === 'menu'}}" class="page menu-page stagger">
    <view class="page-header">
      <view><text class="page-kicker">OUR KITCHEN</text><text class="page-title">今天想吃什么？</text></view>
      <view class="header-cart" bindtap="openCart" hover-class="tap-scale--active">
        <text>⌑</text><text wx:if="{{cartCount}}" class="header-cart-badge">{{cartCount}}</text>
      </view>
    </view>

    <view class="search-row">
      <view class="search-box">
        <text class="search-icon">⌕</text>
        <input class="search-input" value="{{searchKeyword}}" bindinput="onSearch" placeholder="搜一搜想吃的菜" placeholder-class="input-placeholder" />
        <text wx:if="{{searchKeyword}}" class="search-clear" bindtap="clearSearch">×</text>
      </view>
      <view class="dice-button" bindtap="openRandomDish" hover-class="tap-scale--active" aria-label="今天吃什么">🎲</view>
    </view>

    <scroll-view class="category-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="category-row">
        <view
          wx:for="{{categories}}"
          wx:key="id"
          class="category-pill {{currentCategory === item.id ? 'is-active' : ''}}"
          data-id="{{item.id}}"
          bindtap="selectCategory"
        ><text>{{item.icon}}</text><text>{{item.name}}</text></view>
      </view>
    </scroll-view>

    <view wx:if="{{filteredItems.length}}" class="food-grid food-stagger">
      <view wx:for="{{filteredItems}}" wx:key="viewKey" id="dish-card-{{item.id}}" class="food-card">
        <view class="food-art tone-{{item.tone}}">
          <view class="food-art-glow"></view>
          <image wx:if="{{item.image}}" class="food-image" src="{{item.image}}" mode="aspectFit" lazy-load="{{true}}"></image>
          <text wx:else class="food-emoji">{{item.emoji}}</text>
          <text wx:if="{{item.recommended}}" class="recommend-mark">今日推荐</text>
        </view>
        <view class="food-info">
          <text class="food-name">{{item.name}}</text>
          <text class="food-desc">{{item.description}}</text>
          <view class="food-tags"><text wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text></view>
          <view class="add-button" data-id="{{item.id}}" bindtap="addToCart" hover-class="add-pressed">＋</view>
        </view>
      </view>
    </view>
    <view wx:else class="menu-empty">
      <view class="empty-art">🍽️</view>
      <text class="empty-title">没找到这道菜</text>
      <text class="empty-subtitle">换个关键词试试吧</text>
      <button bindtap="clearSearch">看看全部推荐</button>
    </view>
  </view>

  <!-- 心愿单 -->
  <view wx:elif="{{activeTab === 'wishlist'}}" class="page wishlist-page stagger">
    <view class="wishlist-hero-card">
      <view class="wishlist-hero-copy">
        <text class="page-kicker">WISH MAP</text>
        <text class="wishlist-title">想一起做的事</text>
        <text class="wishlist-subtitle">把“以后有空”先好好收起来</text>
      </view>
      <view class="wishlist-hero-mark">☆</view>
    </view>

    <view class="wishlist-stats">
      <view><text>{{wishStats.pending}}</text><text>待实现</text></view>
      <view><text>{{wishStats.completed}}</text><text>已实现</text></view>
      <view><text>{{wishStats.total}}</text><text>全部心愿</text></view>
    </view>

    <view class="wishlist-action-row">
      <view><text class="section-title">愿望卡片</text><text class="section-subtitle">长按卡片可以删除</text></view>
      <view class="new-wish-button" bindtap="openWishComposer" hover-class="new-wish-button--pressed">＋</view>
    </view>

    <view wx:if="{{wishes.length}}" class="wish-card-list">
      <view
        wx:for="{{wishes}}"
        wx:key="id"
        class="wish-card {{item.completed ? 'is-realized' : ''}}"
        data-id="{{item.id}}"
        bindlongpress="deleteWish"
        hover-class="wish-card--pressed"
      >
        <view class="wish-card-top">
          <view class="wish-card-stamp">{{item.completed ? '✓' : '☆'}}</view>
          <text class="wish-status">{{item.completed ? '已经实现' : '一起期待'}}</text>
        </view>
        <text class="wish-card-title">{{item.title}}</text>
        <text wx:if="{{item.note}}" class="wish-card-note">{{item.note}}</text>
        <view class="wish-card-bottom">
          <text>{{item.completed ? '这件事已经有了回忆' : '先放进以后的小计划'}}</text>
          <button data-id="{{item.id}}" catchtap="toggleWish">{{item.completed ? '再期待' : '实现啦'}}</button>
        </view>
      </view>
    </view>
    <view wx:else class="wish-page-empty">
      <view>☆</view>
      <text>还没有心愿卡片</text>
      <button bindtap="openWishComposer" hover-class="button-pressed">写下第一个</button>
    </view>
  </view>

  <!-- 农场 -->
  <view wx:elif="{{activeTab === 'farm'}}" class="page farm-page stagger">
    <image class="farm-page-bg" src="{{farmImages.pageBg}}" mode="aspectFill"></image>
    <view class="page-header farm-header">
      <view><text class="page-kicker">LITTLE FARM</text><text class="page-title">我们的小农场</text></view>
      <view class="farm-wallet"><text>☀</text><text>{{farmStats.coins}}</text></view>
    </view>

    <view class="farm-hero">
      <image class="farm-hero-image" src="{{farmImages.hero}}" mode="aspectFill"></image>
      <view class="farm-hero-shade"></view>
      <view class="farm-hero-copy">
        <text class="farm-hero-title">种一点今天的期待</text>
        <text class="farm-hero-subtitle">成熟后收进仓库，也会返还阳光金币</text>
      </view>
      <button class="farm-bonus-button {{farmStats.dailyAvailable ? '' : 'is-disabled'}}" bindtap="claimFarmDailyBonus" hover-class="button-pressed">{{farmStats.dailyAvailable ? '领每日阳光' : '今日已领取'}}</button>
    </view>

    <view class="farm-mood-strip">
      <view><text>☀</text><text>阳光 {{farmStats.coins}}</text></view>
      <view><text>♧</text><text>菜园 {{farmStats.planted}}/6</text></view>
      <view><text>⌑</text><text>{{farmStats.ready ? '有收成' : '慢慢长'}}</text></view>
    </view>

    <view class="farm-panel farm-stats-shell">
      <image class="farm-panel-bg" src="{{farmImages.panelBg}}" mode="aspectFill"></image>
      <view class="farm-stats">
        <view><text>{{farmStats.planted}}</text><text>已种下</text></view>
        <view><text>{{farmStats.ready}}</text><text>可收获</text></view>
        <view><text>{{farmStats.harvests}}</text><text>仓库作物</text></view>
      </view>
    </view>

    <view class="section-heading farm-section-heading">
      <view><text class="section-title">选择种子</text><text class="section-subtitle">点空地播种，点作物浇水或收获</text></view>
    </view>
    <view class="farm-panel farm-seed-tray">
      <image class="farm-panel-bg" src="{{farmImages.panelBg}}" mode="aspectFill"></image>
      <view class="farm-crop-grid">
        <view
          wx:for="{{farmCrops}}"
          wx:key="id"
          class="farm-crop-chip tone-{{item.tone}} {{selectedFarmCrop === item.id ? 'is-active' : ''}}"
          data-id="{{item.id}}"
          bindtap="selectFarmCrop"
          hover-class="tap-scale--active"
        >
          <text class="farm-crop-check">✓</text>
          <image class="farm-crop-image" src="{{item.image}}" mode="aspectFill"></image>
          <view class="farm-crop-info">
            <text class="farm-crop-name">{{item.name}}</text>
            <view class="farm-crop-meta">
              <text>☀ {{item.seedCost}}</text>
              <text>{{item.growMinutes}}分</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="farm-field-shell">
      <image class="farm-field-image" src="{{farmImages.field}}" mode="aspectFill"></image>
      <view class="farm-field">
        <view
          wx:for="{{farmPlots}}"
          wx:key="id"
          class="farm-plot farm-plot-{{item.id}} {{item.empty ? 'is-empty' : ''}} {{item.ready ? 'is-ready' : ''}}"
          data-id="{{item.id}}"
          bindtap="tapFarmPlot"
          hover-class="farm-plot--pressed"
        >
          <view wx:if="{{!item.empty}}" class="farm-crop-pin">
            <image wx:if="{{item.growthStage === 'sprout'}}" class="farm-growth-image farm-growth-image--sprout" src="{{farmImages.growthSprout}}" mode="aspectFit"></image>
            <image wx:elif="{{item.growthStage === 'seedling'}}" class="farm-growth-image farm-growth-image--seedling" src="{{farmImages.growthSeedling}}" mode="aspectFit"></image>
            <image wx:elif="{{item.growthStage === 'growing'}}" class="farm-growth-image farm-growth-image--growing" src="{{farmImages.growthGrowing}}" mode="aspectFit"></image>
            <image wx:else class="farm-growth-image farm-growth-image--ready" src="{{farmImages.growthReady}}" mode="aspectFit"></image>
            <view class="farm-crop-tag">
              <text>{{item.ready ? '收获' : item.stageText}}</text>
              <view class="farm-progress"><view style="width: {{item.progress}}%"></view></view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="section-heading farm-section-heading">
      <view><text class="section-title">小仓库</text><text class="section-subtitle">收获会留在这里</text></view>
    </view>
    <view wx:if="{{farmInventoryList.length}}" class="farm-inventory">
      <view wx:for="{{farmInventoryList}}" wx:key="id" class="farm-inventory-item">
        <text>{{item.emoji}}</text>
        <view><text>{{item.name}}</text><text>× {{item.count}}</text></view>
      </view>
    </view>
    <view wx:else class="farm-panel farm-empty-store">
      <image class="farm-panel-bg" src="{{farmImages.panelBg}}" mode="aspectFill"></image>
      <view class="farm-empty-visual">
        <image class="farm-empty-image" src="{{farmImages.basketEmpty}}" mode="aspectFit"></image>
      </view>
      <view class="farm-empty-copy">
        <text class="farm-empty-title">等第一份收成</text>
        <text class="farm-empty-subtitle">成熟后会自动收进这里</text>
        <view class="farm-empty-slots">
          <text>＋</text>
          <text>＋</text>
          <text>＋</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 待办 -->
  <view wx:elif="{{activeTab === 'todo'}}" class="page todo-page stagger">
    <view class="page-header todo-page-header">
      <view><text class="page-kicker">LITTLE THINGS</text><text class="page-title">生活待办</text></view>
      <view class="todo-date-icon">{{todoStats.percent}}<text>%</text></view>
    </view>

    <view class="progress-card">
      <view class="progress-top">
        <view><text class="progress-title">今天也在认真生活</text><text class="progress-copy">已完成 {{todoStats.completed}} 件，还有 {{todoStats.pending}} 件小事</text></view>
        <view class="progress-sun">☀</view>
      </view>
      <view class="progress-track"><view class="progress-fill" style="width: {{todoStats.percent}}%"></view></view>
    </view>

    <view class="todo-toolbar">
      <view class="filter-tabs">
        <text class="{{todoFilter === 'all' ? 'is-active' : ''}}" data-filter="all" bindtap="setTodoFilter">全部 {{todoStats.total}}</text>
        <text class="{{todoFilter === 'pending' ? 'is-active' : ''}}" data-filter="pending" bindtap="setTodoFilter">进行中</text>
        <text class="{{todoFilter === 'completed' ? 'is-active' : ''}}" data-filter="completed" bindtap="setTodoFilter">已完成</text>
      </view>
      <text class="toolbar-hint">长按删除</text>
    </view>

    <view wx:if="{{visibleTodos.length}}" class="todo-list">
      <view
        wx:for="{{visibleTodos}}"
        wx:key="id"
        class="todo-item {{item.completed ? 'is-completed' : ''}}"
        data-id="{{item.id}}"
        bindlongpress="deleteTodo"
        bindtap="editTodo"
        hover-class="todo-item--pressed"
      >
        <view class="todo-checkbox" data-id="{{item.id}}" catchtap="toggleTodo"><text wx:if="{{item.completed}}">✓</text></view>
        <view class="todo-main">
          <text class="todo-title">{{item.title}}</text>
          <text wx:if="{{item.note}}" class="todo-note">{{item.note}}</text>
          <view class="todo-meta"><text class="todo-category category-{{item.categoryClass}}">{{item.category}}</text><text class="todo-due">◷ {{item.due}}</text></view>
        </view>
        <text class="todo-more">···</text>
      </view>
    </view>
    <view wx:else class="todo-empty">
      <view class="empty-art">🫶</view>
      <text class="empty-title">这里空空的</text>
      <text class="empty-subtitle">给今天加一件值得期待的小事吧</text>
    </view>
    <button class="new-todo-button" bindtap="openTodoComposer" hover-class="button-pressed"><text>＋</text> 新建待办</button>
  </view>

  <!-- 我的 -->
  <view wx:else class="page profile-page stagger">
    <view class="profile-hero">
      <view class="profile-bubble bubble-one">♡</view>
      <view class="profile-bubble bubble-two">✦</view>
      <view class="profile-avatar"><text>☺</text><view>♥</view></view>
      <text class="profile-title">我们的小家</text>
      <text class="profile-subtitle">认真吃饭，好好生活</text>
    </view>

    <view class="stats-card">
      <view><text class="stats-number">{{profileStats.orders}}</text><text class="stats-label">次点餐</text></view>
      <view class="stats-divider"></view>
      <view><text class="stats-number">{{profileStats.todos}}</text><text class="stats-label">件已完成</text></view>
      <view class="stats-divider"></view>
      <view><text class="stats-number">{{profileStats.pending}}</text><text class="stats-label">件待完成</text></view>
    </view>

    <view class="profile-section-title order-section-title">
      <text>最近订单</text>
      <text wx:if="{{orders.length > 3}}" class="section-more" bindtap="openAllOrders">查看全部 →</text>
    </view>
    <view wx:if="{{orders.length}}" class="order-list">
      <view wx:for="{{recentOrders}}" wx:key="id" class="order-card" data-id="{{item.id}}" bindtap="openOrderDetail" bindlongpress="deleteOrder" hover-class="order-card--pressed">
        <view class="order-icon">
          <image wx:if="{{item.firstItem.image}}" class="small-food-image" src="{{item.firstItem.image}}" mode="aspectFit" lazy-load="{{true}}"></image>
          <text wx:else>{{item.firstItem.emoji}}</text>
        </view>
        <view class="order-copy"><text class="order-title">{{item.itemSummary}}</text><text class="order-time">{{item.createdAt}} · 订单 #{{item.id}}</text></view>
        <view class="order-side"><text class="order-status">{{item.status}}</text><text class="order-arrow">›</text></view>
      </view>
    </view>
    <view wx:else class="empty-order"><text>🍽</text><view><text>还没有点过餐</text><text>今晚就从喜欢的菜开始吧</text></view><text data-target="menu" bindtap="navigateFromCard">去点餐 →</text></view>

    <view class="profile-section-title">更多</view>
    <view class="settings-card">
      <view class="setting-row" bindtap="openMenuManager">
        <view class="setting-icon setting-menu">＋</view><text>菜单管理</text>
        <text wx:if="{{customMenuItems.length}}" class="setting-value">{{customMenuItems.length}} 道自定义</text><text wx:else class="setting-value">新增菜品</text><text class="setting-arrow">›</text>
      </view>
      <view class="setting-row" bindtap="openFamilyPanel">
        <view class="setting-icon setting-cloud">☁</view><text>家庭云空间</text>
        <text class="setting-value">{{familyStatus === 'active' ? '已同步' : '去连接'}}</text><text class="setting-arrow">›</text>
      </view>
      <view class="setting-row setting-share">
        <view class="setting-icon setting-orange">↗</view><text>分享小家菜单</text><text class="setting-arrow">›</text>
        <button class="share-hit-area" open-type="share" aria-label="分享小家菜单"></button>
      </view>
      <view class="setting-row" bindtap="showAbout"><view class="setting-icon setting-pink">♡</view><text>关于小家菜单</text><text class="setting-arrow">›</text></view>
      <view class="setting-row" bindtap="clearAllData"><view class="setting-icon setting-gray">↻</view><text>清空本地数据</text><text class="setting-arrow">›</text></view>
    </view>
    <view class="version">小家菜单 · 1.0.0</view>
  </view>
</scroll-view>

<!-- 菜单页购物车浮条 -->
<view wx:if="{{activeTab === 'menu' && cartCount > 0 && !showCart}}" class="cart-float" bindtap="openCart" hover-class="cart-float--pressed">
  <view class="cart-float-icon">⌑<text>{{cartCount}}</text></view>
  <view class="cart-float-copy"><text>已选 {{cartCount}} 份</text><text>再选一点喜欢的</text></view>
  <view class="cart-float-total"><text>选好了</text><text>去确认 →</text></view>
</view>

<!-- 加购卡片飞入动画 -->
<view
  wx:if="{{flyingItem.visible}}"
  class="flying-dish-card"
  style="left: {{flyingItem.x}}px; top: {{flyingItem.y}}px; width: {{flyingItem.width}}px; height: {{flyingItem.height}}px; --fly-end-x: {{flyingItem.endX}}px; --fly-end-y: {{flyingItem.endY}}px; --fly-end-rotate: {{flyingItem.endRotate}}deg;"
>
  <view class="flying-card-art tone-{{flyingItem.tone}}">
    <image wx:if="{{flyingItem.image}}" class="flying-food-image" src="{{flyingItem.image}}" mode="aspectFit"></image>
    <text wx:else>{{flyingItem.emoji}}</text>
  </view>
  <view class="flying-card-copy"><text>{{flyingItem.name}}</text><text>{{flyingItem.highlight}}</text></view>
  <view class="flying-card-heart">♥</view>
</view>

<bottom-nav active="{{activeTab}}" badge="{{cartCount}}" wish-badge="{{wishStats.pending}}" bindchange="setTab"></bottom-nav>

<!-- 家庭云空间 -->
<view wx:if="{{showFamilyPanel}}" class="family-overlay" bindtap="closeFamilyPanel">
  <view class="family-card" catchtap="noop">
    <view class="family-card-close" bindtap="closeFamilyPanel">×</view>

    <block wx:if="{{familyStatus === 'loading'}}">
      <view class="family-cloud-icon is-loading">☁</view>
      <text class="family-title">正在连接小家</text>
      <text class="family-copy">稍等一下，正在看看云端有没有我们的家</text>
    </block>

    <block wx:elif="{{familyStatus === 'active'}}">
      <view class="family-cloud-icon">♥</view>
      <text class="family-title">{{family.name}}</text>
      <text class="family-copy">已有 {{family.memberCount}} 位成员，数据每 12 秒自动同步</text>
      <view class="family-active-card"><text>☁</text><view><text>云端同步正常 · 你是{{family.roleLabel}}</text><text>{{family.isAdmin ? '把邀请码发给家人，即可一起加入' : '由管理员邀请并管理成员'}}</text></view></view>
      <view wx:if="{{family.isAdmin && family.inviteCode}}" class="family-invite-row" bindtap="copyInviteCode">
        <view class="family-invite-info"><text class="family-invite-label">邀请码</text><text class="family-invite-code">{{family.inviteCode}}</text></view>
        <text class="family-invite-copy">复制</text>
      </view>
      <button class="family-primary-button" bindtap="openMemberManager">成员管理</button>
      <button class="family-secondary-button" bindtap="closeFamilyPanel">知道啦</button>
      <text class="family-link danger" bindtap="leaveFamily">{{family.isAdmin ? '解散云空间' : '退出云空间'}}</text>
    </block>

    <block wx:elif="{{familyStatus === 'offline'}}">
      <view class="family-cloud-icon is-offline">☁</view>
      <text class="family-title">云端暂时没连上</text>
      <text class="family-copy">{{familyError || '本地功能仍然可以正常使用'}}</text>
      <button class="family-primary-button" bindtap="retryCloud">重新连接</button>
    </block>

    <block wx:elif="{{familyMode === 'create'}}">
      <view class="family-cloud-icon">♡</view>
      <text class="family-title">创建家庭云空间</text>
      <text class="family-copy">创建后你将成为管理员，并自动生成邀请码，发给家人即可加入</text>
      <input class="invite-input family-nickname-input" value="{{familyNickname}}" bindinput="onFamilyNicknameInput" maxlength="12" placeholder="你的昵称（选填）" placeholder-class="input-placeholder" />
      <text wx:if="{{familyError}}" class="family-error">{{familyError}}</text>
      <button class="family-primary-button" bindtap="createFamily" loading="{{familyBusy}}">{{familyBusy ? '正在创建…' : '创建并成为管理员'}}</button>
      <text class="family-link" data-mode="choose" bindtap="setFamilyMode">‹ 返回</text>
    </block>

    <block wx:elif="{{familyMode === 'join'}}">
      <view class="family-cloud-icon">♡</view>
      <text class="family-title">加入家庭云空间</text>
      <text class="family-copy">输入管理员分享的邀请码，以成员身份加入</text>
      <input class="invite-input" value="{{familyInviteCode}}" bindinput="onFamilyInviteCodeInput" maxlength="6" placeholder="输入邀请码" placeholder-class="input-placeholder" />
      <input class="invite-input family-nickname-input" value="{{familyNickname}}" bindinput="onFamilyNicknameInput" maxlength="12" placeholder="你的昵称（选填）" placeholder-class="input-placeholder" />
      <text wx:if="{{familyError}}" class="family-error">{{familyError}}</text>
      <button class="family-primary-button" bindtap="joinFamily" loading="{{familyBusy}}">{{familyBusy ? '正在加入…' : '加入小家'}}</button>
      <text class="family-link" data-mode="choose" bindtap="setFamilyMode">‹ 返回</text>
    </block>

    <block wx:else>
      <view class="family-cloud-icon">♡</view>
      <text class="family-title">进入家庭云空间</text>
      <text class="family-copy">创建一个新的云空间，或用邀请码加入已有的小家</text>
      <button class="family-primary-button" data-mode="create" bindtap="setFamilyMode">创建云空间</button>
      <button class="family-secondary-button" data-mode="join" bindtap="setFamilyMode">加入云空间</button>
      <text class="family-tip">也可以先关闭，继续使用本地模式。</text>
    </block>
  </view>
</view>

<!-- 购物车 -->
<view wx:if="{{showCart}}" class="overlay" bindtap="closeCart">
  <view class="bottom-sheet cart-sheet" catchtap="noop">
    <view class="sheet-handle"></view>
    <view class="sheet-header"><view><text class="sheet-title">今晚吃这些</text><text class="sheet-subtitle">已选 {{cartCount}} 份，都是喜欢的</text></view><view class="sheet-close" bindtap="closeCart">×</view></view>
    <scroll-view class="cart-list" scroll-y show-scrollbar="{{false}}">
      <view wx:for="{{cartItems}}" wx:key="id" class="cart-item">
        <view class="cart-item-art tone-{{item.tone}}">
          <image wx:if="{{item.image}}" class="small-food-image" src="{{item.image}}" mode="aspectFit" lazy-load="{{true}}"></image>
          <text wx:else>{{item.emoji}}</text>
        </view>
        <view class="cart-item-copy"><text>{{item.name}}</text><text>{{item.tagSummary}}</text></view>
        <view class="quantity-control">
          <text data-id="{{item.id}}" data-delta="-1" bindtap="changeCartQuantity">−</text>
          <text>{{item.quantity}}</text>
          <text class="quantity-add" data-id="{{item.id}}" data-delta="1" bindtap="changeCartQuantity">＋</text>
        </view>
      </view>
    </scroll-view>
    <view class="remark-box"><text>✎</text><input value="{{orderRemark}}" bindinput="onRemarkInput" placeholder="口味、忌口或想说的话…" placeholder-class="input-placeholder" /></view>
    <view class="checkout-row">
      <view class="checkout-total"><text>今晚准备</text><view>{{cartCount}}<text> 份</text></view></view>
      <button bindtap="submitOrder" hover-class="button-pressed">就吃这些 <text>→</text></button>
    </view>
  </view>
</view>

<!-- 全部订单 -->
<view wx:if="{{showAllOrders}}" class="overlay" bindtap="closeAllOrders">
  <view class="bottom-sheet all-orders-sheet" catchtap="noop">
    <view class="sheet-handle"></view>
    <view class="sheet-header"><view><text class="sheet-title">全部订单</text><text class="sheet-subtitle">长按可以删除订单</text></view><view class="sheet-close" bindtap="closeAllOrders">×</view></view>
    <scroll-view wx:if="{{ordersView.length}}" class="all-orders-list" scroll-y show-scrollbar="{{false}}">
      <view wx:for="{{ordersView}}" wx:key="id" class="order-card" data-id="{{item.id}}" bindtap="openOrderDetail" bindlongpress="deleteOrder" hover-class="order-card--pressed">
        <view class="order-icon">
          <image wx:if="{{item.firstItem.image}}" class="small-food-image" src="{{item.firstItem.image}}" mode="aspectFit" lazy-load="{{true}}"></image>
          <text wx:else>{{item.firstItem.emoji}}</text>
        </view>
        <view class="order-copy"><text class="order-title">{{item.itemSummary}}</text><text class="order-time">{{item.createdAt}} · 订单 #{{item.id}}</text></view>
        <view class="order-side"><text class="order-status">{{item.status}}</text><text class="order-arrow">›</text></view>
      </view>
    </scroll-view>
    <view wx:else class="messages-sheet-empty"><text>🍽</text><text>还没有订单</text></view>
  </view>
</view>

<!-- 订单详情 -->
<view wx:if="{{showOrderDetail}}" class="overlay" bindtap="closeOrderDetail">
  <view class="bottom-sheet order-detail-sheet" catchtap="noop">
    <view class="sheet-handle"></view>
    <view class="sheet-header">
      <view><text class="sheet-title">这次吃了什么</text><text class="sheet-subtitle">订单 #{{selectedOrder.id}}</text></view>
      <view class="sheet-close" bindtap="closeOrderDetail">×</view>
    </view>
    <view class="order-detail-status"><view class="order-status-icon">✓</view><view><text>{{selectedOrder.status}}</text><text>小家的每一餐都值得记住</text></view></view>
    <view class="order-detail-list">
      <view wx:for="{{selectedOrder.items}}" wx:key="id" class="order-detail-item">
        <view class="order-detail-food">
          <image wx:if="{{item.image}}" class="small-food-image" src="{{item.image}}" mode="aspectFit" lazy-load="{{true}}"></image>
          <text wx:else>{{item.emoji}}</text>
        </view>
        <text class="order-detail-name">{{item.name}}</text>
        <text class="order-detail-quantity">× {{item.quantity}}</text>
      </view>
    </view>
    <view class="order-detail-meta">
      <view><text>下单时间</text><text>{{selectedOrder.createdAt}}</text></view>
      <view><text>口味备注</text><text>{{selectedOrder.remark || '没有特别备注'}}</text></view>
    </view>
    <button class="order-detail-button" bindtap="closeOrderDetail" hover-class="button-pressed">知道啦</button>
  </view>
</view>

<!-- 待办编辑器 -->
<view wx:if="{{showTodoComposer}}" class="overlay" bindtap="closeTodoComposer">
  <view class="bottom-sheet todo-sheet" catchtap="noop">
    <view class="sheet-handle"></view>
    <view class="sheet-header"><view><text class="sheet-title">{{editingTodoId ? '编辑这件小事' : '记一件小事'}}</text><text class="sheet-subtitle">把生活慢慢装进清单里</text></view><view class="sheet-close" bindtap="closeTodoComposer">×</view></view>
    <view class="form-group"><text class="form-label">要做什么</text><input class="form-input form-input-main" value="{{todoDraft.title}}" bindinput="onTodoTitleInput" maxlength="30" focus="{{showTodoComposer}}" placeholder="例如：买一束喜欢的花" placeholder-class="input-placeholder" /></view>
    <view class="form-group"><text class="form-label">补充说明 <text>选填</text></text><input class="form-input" value="{{todoDraft.note}}" bindinput="onTodoNoteInput" maxlength="40" placeholder="加一点小提示" placeholder-class="input-placeholder" /></view>
    <view class="form-group"><text class="form-label">分类</text><view class="option-row"><text wx:for="{{todoCategories}}" wx:key="*this" class="option-chip {{todoDraft.category === item ? 'is-active' : ''}}" data-value="{{item}}" bindtap="selectTodoCategory">{{item}}</text></view></view>
    <view class="form-group"><text class="form-label">什么时候</text><view class="option-row"><text wx:for="{{dueOptions}}" wx:key="*this" class="option-chip {{todoDraft.due === item ? 'is-active' : ''}}" data-value="{{item}}" bindtap="selectTodoDue">{{item}}</text></view></view>
    <button class="save-todo-button" bindtap="saveTodo" hover-class="button-pressed">{{editingTodoId ? '保存修改' : '加入今日清单'}}</button>
  </view>
</view>

<!-- 新增心愿 -->
<view wx:if="{{showWishComposer}}" class="overlay" bindtap="closeWishComposer">
  <view class="bottom-sheet wish-composer-sheet" catchtap="noop">
    <view class="sheet-handle"></view>
    <view class="sheet-header"><view><text class="sheet-title">写一张心愿卡</text><text class="sheet-subtitle">不是任务，是想一起拥有的以后</text></view><view class="sheet-close" bindtap="closeWishComposer">×</view></view>
    <view class="wish-form">
      <input class="wish-input" value="{{wishDraft.title}}" bindinput="onWishTitleInput" maxlength="30" focus="{{showWishComposer}}" placeholder="例如：周末去看一场电影" placeholder-class="input-placeholder" />
      <input class="wish-input wish-note-input" value="{{wishDraft.note}}" bindinput="onWishNoteInput" maxlength="40" placeholder="补充一句小备注" placeholder-class="input-placeholder" />
      <button class="save-wish-button" bindtap="saveWish" hover-class="button-pressed">记到心愿单</button>
    </view>
  </view>
</view>

<!-- 菜单管理 -->
<view wx:if="{{showMenuManager}}" class="overlay" bindtap="closeMenuManager">
  <view class="bottom-sheet menu-manager-sheet" catchtap="noop">
    <view class="sheet-handle"></view>
    <view class="sheet-header"><view><text class="sheet-title">菜单管理</text><text class="sheet-subtitle">{{editingMenuId ? '修改这道菜的信息' : '新增、编辑或删除小家的菜'}}</text></view><view class="sheet-close" bindtap="closeMenuManager">×</view></view>
    <scroll-view class="menu-manager-scroll" scroll-y show-scrollbar="{{false}}">
      <view wx:if="{{customMenuItems.length}}" class="managed-menu-list">
        <view wx:for="{{customMenuItems}}" wx:key="id" class="managed-menu-item {{editingMenuId === item.id ? 'is-editing' : ''}}" data-id="{{item.id}}">
          <view class="managed-menu-art tone-{{item.tone}}">
            <image wx:if="{{item.image}}" class="managed-food-image" src="{{item.image}}" mode="aspectFit" lazy-load="{{true}}"></image>
            <text wx:else>{{item.emoji}}</text>
          </view>
          <view class="managed-menu-copy"><text>{{item.name}}</text><text>{{item.tagSummary}}</text></view>
          <text wx:if="{{item.recommended}}" class="managed-menu-mark">推荐</text>
          <view class="managed-menu-actions">
            <text class="managed-menu-action" data-id="{{item.id}}" catchtap="editMenuItem">编辑</text>
            <text class="managed-menu-action remove" data-id="{{item.id}}" catchtap="deleteCustomMenuItem">删除</text>
          </view>
        </view>
      </view>
      <view class="menu-form-divider">{{editingMenuId ? '编辑菜品' : '新增菜品'}}</view>
      <view class="form-group"><text class="form-label">菜名</text><input class="form-input form-input-main" value="{{menuDraft.name}}" data-field="name" bindinput="onMenuDraftInput" maxlength="18" placeholder="例如：椒盐鸡翅" placeholder-class="input-placeholder" /></view>
      <view class="form-group"><text class="form-label">描述 <text>选填</text></text><input class="form-input" value="{{menuDraft.description}}" data-field="description" bindinput="onMenuDraftInput" maxlength="28" placeholder="一句话写下它的味道" placeholder-class="input-placeholder" /></view>
      <view class="menu-form-row">
        <view class="form-group menu-emoji-field"><text class="form-label">图标</text><input class="form-input" value="{{menuDraft.emoji}}" data-field="emoji" bindinput="onMenuDraftInput" maxlength="4" placeholder="🍗" placeholder-class="input-placeholder" /></view>
        <view class="form-group menu-tags-field"><text class="form-label">标签</text><input class="form-input" value="{{menuDraft.tags}}" data-field="tags" bindinput="onMenuDraftInput" maxlength="20" placeholder="下饭、微辣" placeholder-class="input-placeholder" /></view>
      </view>
      <view class="form-group"><text class="form-label">分类</text><view class="option-row"><text wx:for="{{menuCategories}}" wx:key="id" class="option-chip {{menuDraft.category === item.id ? 'is-active' : ''}}" data-value="{{item.id}}" bindtap="selectMenuCategory">{{item.icon}} {{item.name}}</text></view></view>
      <view class="form-group"><text class="form-label">推荐</text><view class="option-row"><text class="option-chip {{menuDraft.recommended ? 'is-active' : ''}}" bindtap="toggleMenuRecommended">加入今日好味</text></view></view>
    </scroll-view>
    <view class="menu-manager-footer">
      <button wx:if="{{editingMenuId}}" class="cancel-menu-button" bindtap="cancelEditMenuItem" hover-class="button-pressed">取消</button>
      <button class="save-menu-button" bindtap="saveMenuItem" hover-class="button-pressed">{{editingMenuId ? '保存修改' : '加入菜单'}}</button>
    </view>
  </view>
</view>

<!-- 下单成功 -->
<view wx:if="{{showOrderSuccess}}" class="success-overlay">
  <view class="success-card">
    <view class="success-confetti confetti-one">✦</view><view class="success-confetti confetti-two">●</view><view class="success-confetti confetti-three">♥</view>
    <view class="success-icon"><text>✓</text></view>
    <text class="success-title">收到啦，准备开饭！</text>
    <text class="success-copy">{{orderSuccessCopy}}</text>
    <button bindtap="finishOrder" hover-class="button-pressed">好呀</button>
  </view>
</view>

<!-- 随机选菜 -->
<view wx:if="{{showRandomDish}}" class="overlay random-overlay" bindtap="closeRandomDish">
  <view class="random-card" catchtap="noop">
    <view class="random-card-close" bindtap="closeRandomDish">×</view>
    <text class="random-kicker">今天吃什么</text>
    <view class="random-dish {{randomRolling ? 'is-rolling' : ''}}">
      <view class="random-dish-art tone-{{randomDish.tone}}">
        <image wx:if="{{randomDish.image}}" class="random-dish-image" src="{{randomDish.image}}" mode="aspectFit"></image>
        <text wx:else class="random-dish-emoji">{{randomDish.emoji}}</text>
      </view>
      <text class="random-dish-name">{{randomDish.name}}</text>
      <text class="random-dish-desc">{{randomDish.description}}</text>
    </view>
    <view class="random-actions">
      <view class="random-btn ghost" bindtap="rollRandomDish" hover-class="tap-scale--active">换一个</view>
      <view class="random-btn solid" data-id="{{randomDish.id}}" bindtap="addRandomToCart" hover-class="tap-scale--active">加入购物车</view>
    </view>
  </view>
</view>

<!-- 纪念日设置 -->
<view wx:if="{{showAnniversarySheet}}" class="overlay anniversary-overlay" bindtap="closeAnniversarySheet">
  <view class="random-card anniversary-card-sheet" catchtap="noop">
    <view class="random-card-close" bindtap="closeAnniversarySheet">×</view>
    <text class="random-kicker">记录我们的纪念日</text>
    <view class="anniversary-form">
      <text class="form-label">标题</text>
      <input class="anniversary-input" value="{{anniversaryDraft.title}}" bindinput="onAnniversaryTitleInput" maxlength="12" placeholder="例如：在一起" placeholder-class="input-placeholder" />
      <text class="form-label">开始的日子</text>
      <picker class="anniversary-picker" mode="date" value="{{anniversaryDraft.date}}" end="{{todayDate}}" bindchange="onAnniversaryDateChange">
        <view class="anniversary-picker-value"><text>{{anniversaryDraft.date || '选择日期'}}</text><text class="anniversary-picker-arrow">›</text></view>
      </picker>
      <button class="save-anniversary-button" bindtap="saveAnniversary" hover-class="button-pressed">保存</button>
      <text wx:if="{{anniversary}}" class="anniversary-clear" bindtap="clearAnniversary">清除纪念日</text>
    </view>
  </view>
</view>

<!-- 悄悄话留言板 -->
<view wx:if="{{showMessages}}" class="overlay messages-overlay" bindtap="closeMessages">
  <view class="bottom-sheet messages-sheet" catchtap="noop">
    <view class="sheet-handle"></view>
    <view class="sheet-header"><view><text class="sheet-title">悄悄话</text><text class="sheet-subtitle">把想说的话，轻轻留在这里</text></view><view class="sheet-close" bindtap="closeMessages">×</view></view>
    <scroll-view wx:if="{{messagesDisplay.length}}" class="messages-list" scroll-y show-scrollbar="{{false}}">
      <view wx:for="{{messagesDisplay}}" wx:key="id" class="message-item">
        <view class="message-item-top">
          <text class="message-author">{{item.authorName}}<text wx:if="{{item.isMine}}" class="message-author-me"> · 我</text></text>
          <view class="message-item-side">
            <text class="message-time">{{item.timeText}}</text>
            <text class="message-delete" data-id="{{item.id}}" catchtap="deleteMessage">删除</text>
          </view>
        </view>
        <text class="message-text">{{item.text}}</text>
        <view class="message-reactions">
          <view
            wx:for="{{item.reactionList}}"
            wx:for-item="r"
            wx:key="emoji"
            class="reaction-chip {{r.mine ? 'is-mine' : ''}}"
            data-id="{{item.id}}"
            data-emoji="{{r.emoji}}"
            catchtap="toggleReaction"
          ><text class="reaction-emoji">{{r.emoji}}</text><text wx:if="{{r.count}}" class="reaction-count">{{r.count}}</text></view>
        </view>
      </view>
    </scroll-view>
    <view wx:else class="messages-sheet-empty"><text>✎</text><text>还没有悄悄话，写下第一句吧</text></view>
    <view class="message-compose">
      <input class="message-input" value="{{messageDraft}}" bindinput="onMessageDraftInput" maxlength="80" placeholder="写一句悄悄话…" placeholder-class="input-placeholder" confirm-type="send" bindconfirm="sendMessage" />
      <view class="message-send" bindtap="sendMessage" hover-class="tap-scale--active">发送</view>
    </view>
  </view>
</view>
