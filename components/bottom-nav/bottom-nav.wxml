<view class="nav-shell">
  <view class="nav-bar">
    <view
      wx:for="{{items}}"
      wx:key="id"
      class="nav-item {{active === item.id ? 'is-active' : ''}}"
      data-id="{{item.id}}"
      bindtap="select"
      hover-class="nav-item--pressed"
      aria-role="button"
      aria-label="{{item.label}}"
    >
      <view class="nav-icon-wrap">
        <image class="nav-icon" src="{{active === item.id ? item.iconActive : item.icon}}" mode="aspectFit"></image>
        <text wx:if="{{item.id === 'menu' && badge > 0}}" class="nav-badge">{{badge > 99 ? '99+' : badge}}</text>
        <text wx:if="{{item.id === 'wishlist' && wishBadge > 0}}" class="nav-badge">{{wishBadge > 99 ? '99+' : wishBadge}}</text>
      </view>
      <text class="nav-label">{{item.label}}</text>
    </view>
  </view>
</view>
